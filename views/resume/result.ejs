<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Resume Analysis Result — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue: #2563eb; --blue-dark: #1d4ed8; --blue-mid: #3b82f6;
      --blue-light: #eff6ff; --blue-pale: #dbeafe;
      --white: #fff; --gray-50: #f8fafc; --gray-100: #f1f5f9;
      --gray-200: #e2e8f0; --gray-400: #94a3b8; --gray-500: #64748b;
      --gray-600: #475569; --gray-700: #334155; --gray-800: #1e293b; --gray-900: #0f172a;
      --green: #16a34a; --green-light: #dcfce7;
      --red: #dc2626; --red-light: #fee2e2;
      --yellow: #d97706; --yellow-light: #fef3c7;
      --sidebar-w: 260px; --navbar-h: 64px; --radius: 14px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06); --shadow: 0 4px 16px rgba(0,0,0,0.07);
    }
    body { font-family: 'Inter', sans-serif; background: var(--gray-50); color: var(--gray-800); min-height: 100vh; }

    .navbar { position: fixed; top: 0; left: 0; right: 0; height: var(--navbar-h); background: var(--white); border-bottom: 1px solid var(--gray-200); display: flex; align-items: center; padding: 0 24px; z-index: 100; gap: 16px; }
    .nav-brand { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 800; color: var(--gray-900); text-decoration: none; letter-spacing: -0.5px; }
    .nav-brand-icon { width: 36px; height: 36px; background: linear-gradient(135deg, var(--blue), var(--blue-mid)); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .nav-spacer { flex: 1; }
    .nav-btn { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; border: none; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all 0.15s; }
    .nav-btn-ghost { background: transparent; color: var(--gray-600); border: 1.5px solid var(--gray-200); }
    .nav-btn-ghost:hover { background: var(--gray-100); }
    .nav-btn-primary { background: linear-gradient(135deg, var(--blue), var(--blue-mid)); color: white; box-shadow: 0 2px 8px rgba(37,99,235,0.3); }
    .nav-btn-primary:hover { transform: translateY(-1px); }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; color: var(--gray-600); }

    .sidebar { position: fixed; top: var(--navbar-h); left: 0; width: var(--sidebar-w); height: calc(100vh - var(--navbar-h)); background: var(--white); border-right: 1px solid var(--gray-200); padding: 24px 16px; overflow-y: auto; z-index: 90; transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .sidebar-section { margin-bottom: 28px; }
    .sidebar-label { font-size: 10px; font-weight: 700; color: var(--gray-400); letter-spacing: 1px; text-transform: uppercase; padding: 0 12px; margin-bottom: 8px; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; font-size: 14px; font-weight: 500; color: var(--gray-600); text-decoration: none; transition: all 0.15s; margin-bottom: 2px; }
    .sidebar-link:hover { background: var(--gray-100); color: var(--gray-800); }
    .sidebar-link.active { background: var(--blue-light); color: var(--blue); font-weight: 600; }
    .sidebar-link .s-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; background: var(--gray-100); }
    .sidebar-link.active .s-icon { background: var(--blue-pale); }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 89; }

    .main { margin-left: var(--sidebar-w); margin-top: var(--navbar-h); padding: 32px; display: flex; justify-content: center; }
    .content-wrap { width: 100%; max-width: 860px; }

    /* SCORE HERO */
    .score-hero {
      background: linear-gradient(135deg, var(--blue-dark) 0%, var(--blue) 50%, var(--blue-mid) 100%);
      border-radius: var(--radius); padding: 40px; margin-bottom: 24px;
      color: white; display: flex; align-items: center; gap: 40px; flex-wrap: wrap;
      animation: fadeUp 0.4s ease both;
    }
    .score-ring {
      position: relative; width: 140px; height: 140px; flex-shrink: 0;
    }
    .score-ring svg { transform: rotate(-90deg); }
    .score-ring-num {
      position: absolute; inset: 0; display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .score-ring-num .num { font-size: 38px; font-weight: 800; line-height: 1; }
    .score-ring-num .denom { font-size: 14px; opacity: 0.7; }
    .score-info { flex: 1; }
    .score-info h2 { font-size: 22px; font-weight: 800; margin-bottom: 8px; }
    .score-status-badge {
      display: inline-block; padding: 5px 14px; border-radius: 20px;
      font-size: 13px; font-weight: 700; margin-bottom: 14px;
    }
    .score-status-badge.needs-work { background: rgba(220,38,38,0.25); color: #fca5a5; }
    .score-status-badge.moderate { background: rgba(217,119,6,0.25); color: #fcd34d; }
    .score-status-badge.strong { background: rgba(22,163,74,0.25); color: #86efac; }
    .score-meta-row { display: flex; gap: 24px; flex-wrap: wrap; }
    .score-meta-item { font-size: 13px; opacity: 0.85; }
    .score-meta-item strong { display: block; font-size: 20px; font-weight: 800; opacity: 1; }
    .jd-score-badge {
      background: rgba(255,255,255,0.15); border-radius: 10px;
      padding: 10px 16px; font-size: 14px; font-weight: 600; margin-top: 12px;
      display: inline-block;
    }

    /* CARDS */
    .card {
      background: var(--white); border-radius: var(--radius);
      border: 1px solid var(--gray-200); box-shadow: var(--shadow-sm);
      padding: 24px; margin-bottom: 16px;
      animation: fadeUp 0.4s ease both;
    }
    .card-title {
      font-size: 15px; font-weight: 700; color: var(--gray-800);
      margin-bottom: 16px; display: flex; align-items: center; gap: 8px;
    }

    /* BREAKDOWN */
    .breakdown-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 12px; }
    .breakdown-item {
      background: var(--gray-50); border-radius: 10px; padding: 14px 16px;
      border: 1px solid var(--gray-200);
    }
    .breakdown-key { font-size: 12px; color: var(--gray-500); font-weight: 600; margin-bottom: 4px; text-transform: capitalize; }
    .breakdown-val { font-size: 20px; font-weight: 800; color: var(--blue); }

    /* LISTS */
    .issue-list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .issue-item {
      display: flex; align-items: flex-start; gap: 10px;
      padding: 10px 14px; border-radius: 8px; font-size: 14px; line-height: 1.5;
    }
    .issue-item.red { background: var(--red-light); color: #7f1d1d; }
    .issue-item.yellow { background: var(--yellow-light); color: #78350f; }
    .issue-item.green { background: var(--green-light); color: #14532d; }
    .issue-item .dot { width: 6px; height: 6px; border-radius: 50%; flex-shrink: 0; margin-top: 6px; }
    .issue-item.red .dot { background: var(--red); }
    .issue-item.yellow .dot { background: var(--yellow); }
    .issue-item.green .dot { background: var(--green); }

    /* TAGS */
    .tag-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
    .tag {
      padding: 5px 12px; border-radius: 20px; font-size: 12px; font-weight: 600;
    }
    .tag.red { background: var(--red-light); color: var(--red); }
    .tag.green { background: var(--green-light); color: var(--green); }
    .tag.blue { background: var(--blue-light); color: var(--blue-dark); }

    /* REWRITE */
    .rewrite-item {
      border: 1px solid var(--gray-200); border-radius: 10px; overflow: hidden; margin-bottom: 12px;
    }
    .rewrite-item:last-child { margin-bottom: 0; }
    .rewrite-before { background: var(--red-light); padding: 12px 16px; }
    .rewrite-after { background: var(--green-light); padding: 12px 16px; }
    .rewrite-label { font-size: 10px; font-weight: 700; letter-spacing: 1px; text-transform: uppercase; margin-bottom: 4px; }
    .rewrite-before .rewrite-label { color: var(--red); }
    .rewrite-after .rewrite-label { color: var(--green); }
    .rewrite-text { font-size: 13px; line-height: 1.5; }
    .rewrite-before .rewrite-text { color: #7f1d1d; }
    .rewrite-after .rewrite-text { color: #14532d; }

    /* ACTIONS */
    .action-row { display: flex; gap: 12px; margin-top: 24px; flex-wrap: wrap; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); box-shadow: 4px 0 24px rgba(0,0,0,0.12); }
      .sidebar-overlay.open { display: block; }
      .main { margin-left: 0; padding: 20px 16px; }
      .score-hero { flex-direction: column; align-items: flex-start; gap: 20px; }
    }
  </style>
</head>
<body>

<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/>
    </svg>
  </button>
  <a href="/dashboard" class="nav-brand"><div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div> PrepPilot</a>
  <div class="nav-spacer"></div>
  <a href="/resume" class="nav-btn nav-btn-ghost">← Analyze Again</a>
  <a href="/dashboard" class="nav-btn nav-btn-ghost">Dashboard</a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard</a>
    <a href="/roadmap" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> Roadmap</a>
    <a href="/activity/activity-dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span> DSA Activity</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <a href="/builder" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span> Resume Builder</a>
    <a href="/resume" class="sidebar-link active"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span> ATS Analyzer</a>
    <a href="/api/interview/setup" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></span> AI Interview</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> Profile</a>
    <a href="/logout" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="content-wrap">

    <%
      const score = analysis.atsScore || 0;
      const issueCount = (analysis.criticalIssues?.length || 0) + (analysis.missingKeywords?.length || 0);
      let statusLabel = 'Needs Work';
      let statusClass = 'needs-work';
      if (score >= 80) { statusLabel = 'Strong'; statusClass = 'strong'; }
      else if (score >= 60) { statusLabel = 'Moderate'; statusClass = 'moderate'; }
      const circumference = 2 * Math.PI * 54;
      const dashOffset = circumference - (score / 100) * circumference;
    %>

    <!-- SCORE HERO -->
    <div class="score-hero">
      <div class="score-ring">
        <svg width="140" height="140" viewBox="0 0 140 140">
          <circle cx="70" cy="70" r="54" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="12"/>
          <circle cx="70" cy="70" r="54" fill="none" stroke="white" stroke-width="12"
            stroke-dasharray="<%= circumference %>"
            stroke-dashoffset="<%= dashOffset %>"
            stroke-linecap="round"
            style="transition: stroke-dashoffset 1s ease;"/>
        </svg>
        <div class="score-ring-num">
          <span class="num"><%= score %></span>
          <span class="denom">/100</span>
        </div>
      </div>
      <div class="score-info">
        <h2>ATS Analysis Complete</h2>
        <span class="score-status-badge <%= statusClass %>"><%= statusLabel %></span>
        <div class="score-meta-row">
          <div class="score-meta-item">
            <strong><%= issueCount %></strong>
            Issues Found
          </div>
          <% if (analysis.breakdown) { %>
            <div class="score-meta-item">
              <strong><%= Object.keys(analysis.breakdown).length %></strong>
              Categories Scored
            </div>
          <% } %>
        </div>
        <% if (analysis.jdMatchScore !== undefined && analysis.jdMatchScore !== null) { %>
          <div class="jd-score-badge">JD Match Score: <strong><%= analysis.jdMatchScore %>/100</strong></div>
        <% } %>
      </div>
    </div>

    <!-- BREAKDOWN -->
    <% if (analysis.breakdown && Object.keys(analysis.breakdown).length > 0) { %>
    <div class="card" style="animation-delay:0.05s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Score Breakdown
      </div>
      <div class="breakdown-grid">
        <% Object.entries(analysis.breakdown).forEach(([key, val]) => { %>
          <div class="breakdown-item">
            <div class="breakdown-key"><%= key %></div>
            <div class="breakdown-val"><%= val %></div>
          </div>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- CRITICAL ISSUES -->
    <% if (analysis.criticalIssues && analysis.criticalIssues.length > 0) { %>
    <div class="card" style="animation-delay:0.1s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Critical Issues
      </div>
      <ul class="issue-list">
        <% analysis.criticalIssues.forEach(issue => { %>
          <li class="issue-item red"><span class="dot"></span><%= issue %></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- IMPROVEMENTS -->
    <% if (analysis.improvementSuggestions && analysis.improvementSuggestions.length > 0) { %>
    <div class="card" style="animation-delay:0.15s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        Improvement Suggestions
      </div>
      <ul class="issue-list">
        <% analysis.improvementSuggestions.forEach(s => { %>
          <li class="issue-item yellow"><span class="dot"></span><%= s %></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- MISSING KEYWORDS -->
    <% if (analysis.missingKeywords && analysis.missingKeywords.length > 0) { %>
    <div class="card" style="animation-delay:0.2s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/></svg>
        Missing Keywords
      </div>
      <div class="tag-wrap">
        <% analysis.missingKeywords.forEach(kw => { %>
          <span class="tag red"><%= kw %></span>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- MATCHED SKILLS -->
    <% if (analysis.matchedSkills && analysis.matchedSkills.length > 0) { %>
    <div class="card" style="animation-delay:0.22s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        Matched Skills
      </div>
      <div class="tag-wrap">
        <% analysis.matchedSkills.forEach(s => { %>
          <span class="tag green"><%= s %></span>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- MISSING SKILLS (JD) -->
    <% if (analysis.missingSkills && analysis.missingSkills.length > 0) { %>
    <div class="card" style="animation-delay:0.24s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        Missing Skills (from JD)
      </div>
      <div class="tag-wrap">
        <% analysis.missingSkills.forEach(s => { %>
          <span class="tag red"><%= s %></span>
        <% }) %>
      </div>
    </div>
    <% } %>

    <!-- JD TAILORING -->
    <% if (analysis.tailoringSuggestions && analysis.tailoringSuggestions.length > 0) { %>
    <div class="card" style="animation-delay:0.26s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        JD Tailoring Suggestions
      </div>
      <ul class="issue-list">
        <% analysis.tailoringSuggestions.forEach(s => { %>
          <li class="issue-item green"><span class="dot"></span><%= s %></li>
        <% }) %>
      </ul>
    </div>
    <% } %>

    <!-- REWRITE EXAMPLES -->
    <% if (analysis.rewriteExamples && analysis.rewriteExamples.length > 0) { %>
    <div class="card" style="animation-delay:0.3s">
      <div class="card-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
        Rewrite Suggestions
      </div>
      <% analysis.rewriteExamples.forEach(r => { %>
        <div class="rewrite-item">
          <div class="rewrite-before">
            <div class="rewrite-label">Original</div>
            <div class="rewrite-text"><%= r.original %></div>
          </div>
          <div class="rewrite-after">
            <div class="rewrite-label">Improved</div>
            <div class="rewrite-text"><%= r.improved %></div>
          </div>
        </div>
      <% }) %>
    </div>
    <% } %>

    <div class="action-row">
      <a href="/resume" class="nav-btn nav-btn-primary" style="padding:12px 24px;font-size:14px;">Analyze Another Resume</a>
      <a href="/builder" class="nav-btn nav-btn-ghost" style="padding:12px 24px;font-size:14px;">Open Resume Builder</a>
      <a href="/dashboard" class="nav-btn nav-btn-ghost" style="padding:12px 24px;font-size:14px;">Dashboard</a>
    </div>

  </div>
</main>

<script>
  document.getElementById('hamburgerBtn').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('open');
  });
  document.getElementById('sidebarOverlay').addEventListener('click', () => {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
  });
</script>

</body>
</html>
