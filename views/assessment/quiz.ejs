<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Assessment — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue:#2563eb; --blue-mid:#3b82f6; --blue-light:#eff6ff; --blue-pale:#dbeafe;
      --white:#fff; --gray-50:#f8fafc; --gray-100:#f1f5f9; --gray-200:#e2e8f0;
      --gray-400:#94a3b8; --gray-500:#64748b; --gray-600:#475569;
      --gray-700:#334155; --gray-800:#1e293b; --gray-900:#0f172a;
      --radius:14px; --shadow-sm:0 1px 3px rgba(0,0,0,0.06);
    }
    body { font-family:'Inter',sans-serif; background:var(--gray-50); color:var(--gray-800); min-height:100vh; }

    /* TOP BAR */
    .topbar { height:60px; background:var(--white); border-bottom:1px solid var(--gray-200); display:flex; align-items:center; padding:0 32px; gap:16px; position:sticky; top:0; z-index:10; }
    .topbar-brand { display:flex; align-items:center; gap:10px; font-size:17px; font-weight:800; color:var(--gray-900); text-decoration:none; letter-spacing:-0.4px; }
    .topbar-brand-icon { width:32px; height:32px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-radius:9px; display:flex; align-items:center; justify-content:center; }
    .topbar-spacer { flex:1; }
    .topbar-back { padding:7px 14px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Inter',sans-serif; cursor:pointer; border:1.5px solid var(--gray-200); background:transparent; color:var(--gray-600); text-decoration:none; transition:all 0.15s; }
    .topbar-back:hover { background:var(--gray-100); }

    /* PROGRESS BAR */
    .progress-bar-wrap { height:3px; background:var(--gray-200); }
    .progress-bar-fill { height:3px; background:linear-gradient(90deg,var(--blue),var(--blue-mid)); transition:width 0.4s ease; }

    /* LAYOUT */
    .page-body { display:flex; justify-content:center; padding:40px 20px 60px; }
    .content-wrap { width:100%; max-width:720px; }

    /* HEADER */
    .quiz-header { margin-bottom:28px; animation:fadeUp 0.4s ease both; }
    .topic-badge { display:inline-flex; align-items:center; gap:6px; background:var(--blue-light); color:var(--blue); font-size:12px; font-weight:700; padding:5px 14px; border-radius:20px; margin-bottom:12px; }
    .quiz-header h1 { font-size:24px; font-weight:800; color:var(--gray-900); letter-spacing:-0.4px; margin-bottom:4px; }
    .quiz-header p { font-size:14px; color:var(--gray-500); }

    /* QUESTION CARD */
    .question-card {
      background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-200);
      padding:24px; margin-bottom:16px; box-shadow:var(--shadow-sm);
      animation:fadeUp 0.4s ease both;
    }
    .question-num { font-size:11px; font-weight:700; color:var(--gray-400); letter-spacing:0.5px; text-transform:uppercase; margin-bottom:8px; }
    .question-text { font-size:15px; font-weight:600; color:var(--gray-800); line-height:1.5; margin-bottom:18px; }

    /* OPTIONS */
    .option-list { display:flex; flex-direction:column; gap:10px; }
    .option-label {
      display:flex; align-items:center; gap:12px; padding:12px 16px;
      border:1.5px solid var(--gray-200); border-radius:10px; cursor:pointer;
      transition:all 0.15s; font-size:14px; color:var(--gray-700); font-weight:500;
    }
    .option-label:hover { border-color:var(--blue); background:var(--blue-light); color:var(--blue); }
    .option-label input[type="radio"] { display:none; }
    .option-label input:checked + .option-dot { background:var(--blue); border-color:var(--blue); }
    .option-label:has(input:checked) { border-color:var(--blue); background:var(--blue-light); color:var(--blue); }
    .option-dot {
      width:18px; height:18px; border-radius:50%; border:2px solid var(--gray-300);
      flex-shrink:0; transition:all 0.15s; display:flex; align-items:center; justify-content:center;
    }
    .option-dot::after { content:''; width:8px; height:8px; border-radius:50%; background:white; display:none; }
    .option-label:has(input:checked) .option-dot::after { display:block; }

    /* SUBMIT */
    .submit-wrap { margin-top:28px; }
    .btn-submit {
      width:100%; padding:14px; background:linear-gradient(135deg,var(--blue),var(--blue-mid));
      color:white; border:none; border-radius:10px; font-size:15px; font-weight:700;
      font-family:'Inter',sans-serif; cursor:pointer; transition:all 0.15s;
      box-shadow:0 4px 14px rgba(37,99,235,0.3);
    }
    .btn-submit:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(37,99,235,0.4); }

    /* QUESTION COUNTER */
    .question-counter { display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; font-size:13px; color:var(--gray-500); font-weight:500; }
    .counter-dots { display:flex; gap:6px; }
    .counter-dot { width:8px; height:8px; border-radius:50%; background:var(--gray-200); transition:background 0.2s; }
    .counter-dot.active { background:var(--blue); }

    @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @media(max-width:600px) { .topbar{padding:0 16px} .page-body{padding:24px 12px 40px} }
  </style>
</head>
<body>

<div class="topbar">
  <a href="/dashboard" class="topbar-brand">
    <div class="topbar-brand-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    PrepPilot
  </a>
  <div class="topbar-spacer"></div>
  <a href="/roadmap" class="topbar-back">Back to Roadmap</a>
</div>
<div class="progress-bar-wrap">
  <div class="progress-bar-fill" id="progressFill" style="width:0%"></div>
</div>

<div class="page-body">
  <div class="content-wrap">

    <div class="quiz-header">
      <div class="topic-badge">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <%= assessment.subtopicTitle %>
      </div>
      <h1>Subtopic Assessment</h1>
      <p>Answer all questions carefully. Your results will update your roadmap progress.</p>
    </div>

    <div class="question-counter">
      <span><%= assessment.questions.length %> questions</span>
      <div class="counter-dots" id="counterDots">
        <% assessment.questions.forEach((q, i) => { %>
          <div class="counter-dot" id="dot-<%= i %>"></div>
        <% }) %>
      </div>
    </div>

    <form action="/assessment/submit/<%= assessment._id %>" method="POST" id="quizForm">
      <% assessment.questions.forEach((q, index) => { %>
        <div class="question-card" style="animation-delay:<%= index * 0.05 %>s">
          <div class="question-num">Question <%= index + 1 %> of <%= assessment.questions.length %></div>
          <div class="question-text"><%= q.question %></div>
          <div class="option-list">
            <% q.options.forEach((option, optIndex) => { %>
              <label class="option-label" onclick="markAnswered(<%= index %>)">
                <input type="radio" name="q<%= index %>" value="<%= option %>" required/>
                <div class="option-dot"></div>
                <%= option %>
              </label>
            <% }) %>
          </div>
        </div>
      <% }) %>

      <div class="submit-wrap">
        <button type="submit" class="btn-submit">Submit Assessment</button>
      </div>
    </form>

  </div>
</div>

<script>
  const total = <%= assessment.questions.length %>;
  const answered = new Set();

  function markAnswered(index) {
    answered.add(index);
    document.getElementById('dot-' + index).classList.add('active');
    const pct = Math.round((answered.size / total) * 100);
    document.getElementById('progressFill').style.width = pct + '%';
  }
</script>
</body>
</html>
