<!DOCTYPE html>
<html>
<head>
    <title>Assessment Result - PrepPilot</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background: #f4f6f9;
            padding: 30px;
        }

        .container {
            max-width: 900px;
            margin: auto;
            background: #ffffff;
            padding: 30px;
            border-radius: 14px;
            box-shadow: 0 6px 18px rgba(0,0,0,0.08);
        }

        h1, h2, h3 {
            margin-bottom: 15px;
        }

        .summary-box {
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 25px;
            background: #e8f5e9;
            border: 1px solid #c8e6c9;
        }

        .mastered {
            color: #2e7d32;
            font-weight: bold;
        }

        .revision {
            color: #f57c00;
            font-weight: bold;
        }

        .weak {
            color: #d32f2f;
            font-weight: bold;
        }

        .feedback-box {
            padding: 18px;
            border-radius: 10px;
            background: #e3f2fd;
            border: 1px solid #bbdefb;
            margin-bottom: 25px;
        }

        .gap-box {
            padding: 18px;
            border-radius: 10px;
            background: #fff3e0;
            border: 1px solid #ffe0b2;
            margin-bottom: 25px;
        }

        .question-card {
            margin-bottom: 20px;
            padding: 18px;
            border-radius: 12px;
            border: 1px solid #e0e0e0;
            background: #fafafa;
        }

        .correct {
            color: #2e7d32;
            font-weight: 600;
        }

        .incorrect {
            color: #d32f2f;
            font-weight: 600;
        }

        .explanation {
            margin-top: 8px;
            color: #555;
            font-size: 14px;
        }

        .btn-group {
            margin-top: 30px;
        }

        .btn {
            padding: 12px 18px;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            cursor: pointer;
            margin-right: 10px;
        }

        .retake-btn {
            background: #ff9800;
            color: white;
        }

        .roadmap-btn {
            background: #2196f3;
            color: white;
        }

        .retake-btn:hover {
            background: #fb8c00;
        }

        .roadmap-btn:hover {
            background: #1e88e5;
        }

        .subtopic-tag {
            display: inline-block;
            padding: 8px 14px;
            border-radius: 8px;
            background: #e3f2fd;
            font-weight: 500;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Assessment Result</h1>

    <div class="subtopic-tag">
        Subtopic: <strong><%= assessment.subtopicTitle %></strong>
    </div>

    <!-- 🔥 Summary Section -->
    <div class="summary-box">
        <h2>Score: <%= score %> / <%= assessment.questions.length %></h2>
        <h3>Percentage: <%= percentage %>%</h3>

        <p>
            Mastery Level:
            <% if (assessment.masteryLevel === "mastered") { %>
                <span class="mastered">Mastered ✅</span>
            <% } else if (assessment.masteryLevel === "revision-needed") { %>
                <span class="revision">Revision Needed ⚠️</span>
            <% } else { %>
                <span class="weak">Weak ❌</span>
            <% } %>
        </p>
    </div>

    <!-- 🧠 Smart Feedback -->
    <div class="feedback-box">
        <h3>AI Learning Feedback</h3>
        <p><%= feedback %></p>

        <% if (assessment.masteryLevel === "weak") { %>
            <p class="weak">
                ⚠️ Your foundation on this subtopic is weak. You should revise and retake the assessment before marking it as completed.
            </p>
        <% } else if (assessment.masteryLevel === "revision-needed") { %>
            <p class="revision">
                You have partial understanding. Revise weak concepts and retake for mastery.
            </p>
        <% } else { %>
            <p class="mastered">
                Excellent work! You can confidently move to the next subtopic.
            </p>
        <% } %>
    </div>

    <!-- 📉 Performance Gap Analysis -->
    <% if (weakConcepts && weakConcepts.length > 0) { %>
        <div class="gap-box">
            <h3>Performance Gap Analysis (Weak Concepts)</h3>
            <ul>
                <% weakConcepts.forEach(concept => { %>
                    <li>
                        <strong><%= concept.concept %></strong> — Accuracy: <%= concept.accuracy %>%
                    </li>
                <% }) %>
            </ul>
        </div>
    <% } %>

    <!-- 📚 Detailed Question Review -->
    <h2>Detailed Answer Review</h2>

    <% assessment.questions.forEach((q, index) => { %>
        <div class="question-card">
            <p><strong>Q<%= index + 1 %>:</strong> <%= q.question %></p>

            <p>
                <strong>Your Answer:</strong>
                <% if (q.userAnswer === q.correctAnswer) { %>
                    <span class="correct">
                        <%= q.userAnswer || "Not Answered" %> ✅
                    </span>
                <% } else { %>
                    <span class="incorrect">
                        <%= q.userAnswer || "Not Answered" %> ❌
                    </span>
                <% } %>
            </p>

            <p>
                <strong>Correct Answer:</strong>
                <span class="correct"><%= q.correctAnswer %></span>
            </p>

            <% if (q.explanation && q.explanation.trim() !== "") { %>
                <div class="explanation">
                    <strong>Explanation:</strong> <%= q.explanation %>
                </div>
            <% } %>
        </div>
    <% }) %>

    <!-- 🔁 Action Buttons -->
    <div class="btn-group">
        <a href="/assessment/<%= assessment.taskId %>/<%= assessment.subtopicId %>">
            <button class="btn retake-btn">Retake Assessment</button>
        </a>

        <a href="/roadmap">
            <button class="btn roadmap-btn">Back to Roadmap</button>
        </a>
    </div>

</div>

</body>
</html>
