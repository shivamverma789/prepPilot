<!DOCTYPE html>
<html>
<head>
    <title>My Roadmap - PrepPilot</title>
    <style>
        body {
            font-family: "Segoe UI", Arial, sans-serif;
            background: #f4f6f8;
            margin: 0;
            padding: 30px;
            color: #2c3e50;
        }

        h1 {
            margin-bottom: 25px;
        }

        .phase-box {
            background: #ffffff;
            border: 1px solid #e0e6ed;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 25px;
        }

        .phase-title {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 15px;
            border-bottom: 1px solid #eaecef;
            padding-bottom: 8px;
        }

        .skill-card {
            border: 1px solid #eaecef;
            border-radius: 6px;
            padding: 15px;
            margin-bottom: 15px;
            background: #fafbfc;
        }

        .skill-title {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 8px;
        }

        .meta {
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 10px;
        }

        .progress-bar {
            width: 100%;
            height: 8px;
            background: #e5e7eb;
            border-radius: 5px;
            margin-bottom: 15px;
            overflow: hidden;
        }

        .progress-fill {
            height: 8px;
            background: #2563eb;
        }

        .subtopic-list {
            list-style: none;
            padding-left: 0;
            margin: 0;
        }

        .subtopic-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 8px 10px;
            border-bottom: 1px solid #f0f2f5;
        }

        .subtopic-left {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .subtopic-title {
            font-size: 14px;
            font-weight: 500;
        }

        .actions {
            display: flex;
            gap: 8px;
        }

        .btn {
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 4px;
            border: 1px solid #d1d5db;
            background: #ffffff;
            cursor: pointer;
            text-decoration: none;
            color: #374151;
        }

        .btn:hover {
            background: #f3f4f6;
        }

        .btn-test {
            border-color: #2563eb;
            color: #2563eb;
        }

        .mini-project {
            margin-top: 15px;
            padding: 12px;
            border: 1px dashed #d1d5db;
            border-radius: 6px;
            background: #ffffff;
        }

        .mini-project h4 {
            margin: 0 0 5px 0;
            font-size: 15px;
        }

        .project-btn {
            margin-top: 8px;
            padding: 6px 12px;
            font-size: 13px;
            border-radius: 4px;
            border: none;
            cursor: pointer;
        }

        .start-btn {
            background: #2563eb;
            color: white;
        }

        .complete-btn {
            background: #16a34a;
            color: white;
        }

        a.back {
            display: inline-block;
            margin-top: 20px;
            text-decoration: none;
            color: #2563eb;
            font-weight: 500;
        }
    </style>
</head>
<body>

<h1>Your Personalized Learning Roadmap</h1>

<%
let currentPhase = "";
%>

<% if (tasks.length === 0) { %>
    <p>No roadmap generated yet.</p>
<% } else { %>

    <% tasks.forEach(task => { %>

        <% if (task.phase !== currentPhase) { 
            if (currentPhase !== "") { %>
                </div>
            <% }
            currentPhase = task.phase; %>

            <div class="phase-box">
                <div class="phase-title"><%= task.phase %></div>
        <% } %>

        <div class="skill-card">
            <div class="skill-title"><%= task.title %></div>

            <div class="meta">
                Status: <%= task.phaseStatus %> | Progress: <%= task.progressPercentage %>%
            </div>

            <div class="progress-bar">
                <div class="progress-fill" style="width: <%= task.progressPercentage %>%"></div>
            </div>

            <ul class="subtopic-list">
                <% task.subtopics.forEach(sub => { %>
                    <li class="subtopic-item">
                        
                        <!-- LEFT: Checkbox + Title -->
                        <div class="subtopic-left">
                            <input 
                                type="checkbox"
                                <%= sub.isCompleted ? 'checked' : '' %>
                                onchange="toggleSubtopic('<%= task._id %>', '<%= sub._id %>', this)"
                            />
                            <span class="subtopic-title"><%= sub.title %></span>
                        </div>

                        <!-- RIGHT: Docs | YT | Test (Same Line as requested) -->
                        <div class="actions">
                            <% if (sub.resources && sub.resources.length > 0) { %>
                                <% sub.resources.forEach(r => { %>
                                    <a href="<%= r.url %>" target="_blank" class="btn">
                                        <%= r.type === 'youtube' ? 'YT' : 'Docs' %>
                                    </a>
                                <% }) %>
                            <% } %>

                            <a href="/assessment/<%= task._id %>/<%= sub._id %>" class="btn btn-test">
                                Test
                            </a>
                        </div>

                    </li>
                <% }) %>
            </ul>

            <% if (task.miniProject && task.miniProject.title) { %>
                <div class="mini-project">
                    <h4>Mini Project: <%= task.miniProject.title %></h4>
                    <p style="font-size: 14px; color: #555;"><%= task.miniProject.description %></p>

                    <% if (!task.miniProject.isStarted) { %>
                        <button 
                            class="project-btn start-btn"
                            onclick="startProject('<%= task._id %>')"
                        >
                            Start Project
                        </button>
                    <% } %>

                    <% if (task.miniProject.isStarted && !task.miniProject.isCompleted) { %>
                        <button 
                            class="project-btn complete-btn"
                            onclick="completeProject('<%= task._id %>')"
                        >
                            Mark as Completed
                        </button>
                    <% } %>

                    <% if (task.miniProject.isCompleted) { %>
                        <p style="color: #16a34a; font-weight: 600;">Project Completed ✓</p>
                    <% } %>
                </div>
            <% } %>

        </div>

    <% }) %>

    </div>
<% } %>

<a href="/dashboard" class="back">← Back to Dashboard</a>

<script>
async function toggleSubtopic(taskId, subtopicId, checkbox) {
    try {
        const res = await fetch(`/progress/toggle-subtopic/${taskId}/${subtopicId}?_method=PATCH`, {
            method: "POST"
        });

        if (!res.ok) throw new Error("Update failed");

        const scrollY = window.scrollY;
        location.reload();
        window.scrollTo(0, scrollY);

    } catch (err) {
        checkbox.checked = !checkbox.checked;
        alert("Failed to update progress");
    }
}
</script>
<script>
async function startProject(taskId) {
    try {
        const res = await fetch(`/progress/start-project/${taskId}?_method=PATCH`, {
            method: "POST"
        });

        if (!res.ok) throw new Error();

        location.reload(); // temporary — later we can make smarter UI update

    } catch (err) {
        alert("Failed to start project");
    }
}

async function completeProject(taskId) {
    try {
        const res = await fetch(`/progress/complete-project/${taskId}?_method=PATCH`, {
            method: "POST"
        });

        if (!res.ok) throw new Error();

        location.reload();

    } catch (err) {
        alert("Failed to complete project");
    }
}
</script>
</body>
</html>
