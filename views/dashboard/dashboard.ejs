<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue:#2563eb; --blue-dark:#1d4ed8; --blue-mid:#3b82f6;
      --blue-light:#eff6ff; --blue-pale:#dbeafe;
      --white:#fff; --gray-50:#f8fafc; --gray-100:#f1f5f9;
      --gray-200:#e2e8f0; --gray-300:#cbd5e1; --gray-400:#94a3b8;
      --gray-500:#64748b; --gray-600:#475569; --gray-700:#334155;
      --gray-800:#1e293b; --gray-900:#0f172a;
      --sidebar-w:260px; --navbar-h:64px; --radius:14px;
      --shadow-sm:0 1px 3px rgba(0,0,0,0.06); --shadow:0 4px 16px rgba(0,0,0,0.07);
    }
    body { font-family:'Inter',sans-serif; background:var(--gray-50); color:var(--gray-800); min-height:100vh; }
    /* NAVBAR */
    .navbar { position:fixed; top:0; left:0; right:0; height:var(--navbar-h); background:var(--white); border-bottom:1px solid var(--gray-200); display:flex; align-items:center; padding:0 24px; z-index:100; gap:16px; }
    .nav-brand { display:flex; align-items:center; gap:10px; font-size:18px; font-weight:800; color:var(--gray-900); text-decoration:none; letter-spacing:-0.5px; }
    .nav-brand-icon { width:36px; height:36px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .nav-spacer { flex:1; }
    .nav-btn { padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Inter',sans-serif; cursor:pointer; border:none; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all 0.15s; }
    .nav-btn-ghost { background:transparent; color:var(--gray-600); border:1.5px solid var(--gray-200); }
    .nav-btn-ghost:hover { background:var(--gray-100); border-color:var(--gray-300); }
    .nav-avatar { width:36px; height:36px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-radius:50%; display:flex; align-items:center; justify-content:center; color:white; font-weight:700; font-size:14px; }
    .hamburger { display:none; background:none; border:none; cursor:pointer; padding:6px; border-radius:8px; color:var(--gray-600); }
    /* SIDEBAR */
    .sidebar { position:fixed; top:var(--navbar-h); left:0; width:var(--sidebar-w); height:calc(100vh - var(--navbar-h)); background:var(--white); border-right:1px solid var(--gray-200); padding:24px 16px; overflow-y:auto; z-index:90; transition:transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .sidebar-section { margin-bottom:28px; }
    .sidebar-label { font-size:10px; font-weight:700; color:var(--gray-400); letter-spacing:1px; text-transform:uppercase; padding:0 12px; margin-bottom:8px; }
    .sidebar-link { display:flex; align-items:center; gap:12px; padding:10px 12px; border-radius:10px; font-size:14px; font-weight:500; color:var(--gray-600); text-decoration:none; transition:all 0.15s; margin-bottom:2px; }
    .sidebar-link:hover { background:var(--gray-100); color:var(--gray-800); }
    .sidebar-link.active { background:var(--blue-light); color:var(--blue); font-weight:600; }
    .s-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; background:var(--gray-100); }
    .sidebar-link.active .s-icon { background:var(--blue-pale); }
    .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:89; }
    /* MAIN */
    .main { margin-left:var(--sidebar-w); margin-top:var(--navbar-h); padding:32px; min-height:calc(100vh - var(--navbar-h)); }
    .page-header { margin-bottom:28px; animation:fadeUp 0.4s ease both; }
    .page-header h1 { font-size:26px; font-weight:800; color:var(--gray-900); letter-spacing:-0.5px; }
    .page-header p { font-size:14px; color:var(--gray-500); margin-top:4px; }
    /* STATS */
    .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; margin-bottom:28px; }
    .stat-card { background:var(--white); border-radius:var(--radius); padding:20px 22px; border:1px solid var(--gray-200); box-shadow:var(--shadow-sm); animation:fadeUp 0.4s ease both; transition:transform 0.2s,box-shadow 0.2s; }
    .stat-card:hover { transform:translateY(-2px); box-shadow:var(--shadow); }
    .stat-card:nth-child(1){animation-delay:0.05s} .stat-card:nth-child(2){animation-delay:0.1s} .stat-card:nth-child(3){animation-delay:0.15s} .stat-card:nth-child(4){animation-delay:0.2s}
    .stat-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; margin-bottom:12px; }
    .stat-icon.blue{background:var(--blue-light)} .stat-icon.green{background:#f0fdf4} .stat-icon.purple{background:#faf5ff} .stat-icon.orange{background:#fff7ed}
    .stat-value { font-size:24px; font-weight:800; color:var(--gray-900); letter-spacing:-0.5px; }
    .stat-label { font-size:12px; color:var(--gray-500); margin-top:2px; }
    /* GRID */
    .content-grid { display:grid; grid-template-columns:1.4fr 1fr; gap:20px; }
    .card { background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-200); box-shadow:var(--shadow-sm); overflow:hidden; animation:fadeUp 0.4s ease both; }
    .card:nth-child(1){animation-delay:0.25s} .card:nth-child(2){animation-delay:0.3s} .card:nth-child(3){animation-delay:0.35s}
    .card-header { padding:20px 22px 0; display:flex; align-items:center; justify-content:space-between; }
    .card-title { font-size:15px; font-weight:700; color:var(--gray-800); }
    .card-body { padding:16px 22px 22px; }
    /* FEATURE GRID */
    .feature-grid { display:grid; grid-template-columns:repeat(2,1fr); gap:12px; }
    .feature-card { padding:18px; border-radius:12px; border:1.5px solid var(--gray-200); cursor:pointer; transition:all 0.2s; text-decoration:none; color:inherit; display:block; position:relative; overflow:hidden; }
    .feature-card::before { content:''; position:absolute; inset:0; background:linear-gradient(135deg,var(--blue-light),transparent); opacity:0; transition:opacity 0.2s; }
    .feature-card:hover { border-color:var(--blue); transform:translateY(-2px); box-shadow:0 8px 24px rgba(37,99,235,0.12); }
    .feature-card:hover::before { opacity:1; }
    .fc-icon { width:36px; height:36px; border-radius:9px; background:var(--gray-100); display:flex; align-items:center; justify-content:center; margin-bottom:10px; position:relative; z-index:1; transition:background 0.2s; }
    .feature-card:hover .fc-icon { background:var(--blue-pale); }
    .feature-card-title { font-size:14px; font-weight:700; color:var(--gray-800); margin-bottom:4px; position:relative; z-index:1; }
    .feature-card-desc { font-size:12px; color:var(--gray-500); line-height:1.4; position:relative; z-index:1; }
    .feature-card.primary-action { background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-color:transparent; color:white; }
    .feature-card.primary-action .fc-icon { background:rgba(255,255,255,0.2); }
    .feature-card.primary-action .feature-card-title { color:white; }
    .feature-card.primary-action .feature-card-desc { color:rgba(255,255,255,0.75); }
    .feature-card.primary-action:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(37,99,235,0.4); }
    .feature-card.primary-action::before { display:none; }
    /* SKILLS */
    .skill-item { display:flex; align-items:center; justify-content:space-between; padding:10px 0; border-bottom:1px solid var(--gray-100); }
    .skill-item:last-child { border-bottom:none; }
    .skill-name { font-size:14px; font-weight:500; color:var(--gray-700); }
    .skill-badge { font-size:11px; font-weight:600; padding:3px 10px; border-radius:20px; }
    .skill-badge.beginner{background:#fef9c3;color:#854d0e} .skill-badge.intermediate{background:var(--blue-pale);color:var(--blue-dark)} .skill-badge.advanced{background:#dcfce7;color:#166534}
    /* GOALS */
    .goal-tag { display:inline-flex; align-items:center; gap:6px; background:var(--blue-light); color:var(--blue-dark); padding:6px 12px; border-radius:20px; font-size:12px; font-weight:600; margin:4px 4px 0 0; }
    /* EMPTY */
    .empty-state { text-align:center; padding:28px 20px; color:var(--gray-400); }
    .empty-state svg { margin-bottom:10px; opacity:0.4; }
    .empty-state p { font-size:13px; }
    /* TIP */
    .tip-card { background:linear-gradient(135deg,#eff6ff,#dbeafe); border:1px solid var(--blue-pale); border-radius:var(--radius); padding:20px 22px; margin-top:20px; animation:fadeUp 0.4s 0.4s ease both; }
    .tip-card-title { font-size:13px; font-weight:700; color:var(--blue-dark); margin-bottom:6px; display:flex; align-items:center; gap:8px; }
    .tip-card p { font-size:13px; color:var(--gray-600); line-height:1.5; }
    /* ANIMATIONS */
    @keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }
    /* RESPONSIVE */
    @media(max-width:1100px){.stats-row{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:900px){.content-grid{grid-template-columns:1fr}}
    @media(max-width:768px){
      .hamburger{display:flex} .sidebar{transform:translateX(-100%)}
      .sidebar.open{transform:translateX(0);box-shadow:4px 0 24px rgba(0,0,0,0.12)}
      .sidebar-overlay.open{display:block} .main{margin-left:0;padding:20px 16px}
      .stats-row{grid-template-columns:repeat(2,1fr)} .feature-grid{grid-template-columns:1fr}
      /* hide navbar text buttons on mobile — they live in the sidebar */
      .nav-btn-ghost{display:none}
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/></svg>
  </button>
  <a href="/dashboard" class="nav-brand">
    <div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    PrepPilot
  </a>
  <div class="nav-spacer"></div>
  <div style="display:flex;align-items:center;gap:10px;">
    <a href="/profile" class="nav-btn nav-btn-ghost">Edit Profile</a>
    <a href="/logout" class="nav-btn nav-btn-ghost">Logout</a>
    <div class="nav-avatar"><%= user.name.charAt(0).toUpperCase() %></div>
  </div>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>

<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link active">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span>
      Dashboard
    </a>
    <a href="/roadmap" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span>
      Roadmap
    </a>
    <a href="/activity/activity-dashboard" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span>
      DSA Activity
    </a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <a href="/builder" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg></span>
      Resume Builder
    </a>
    <a href="/resume" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>
      ATS Analyzer
    </a>
    <a href="/api/interview/setup" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></span>
      AI Interview
    </a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span>
      Profile
    </a>
    <a href="/profile/dsa-profiles" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg></span>
      DSA Profiles
    </a>
    <a href="/logout" class="sidebar-link">
      <span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span>
      Logout
    </a>
  </div>
</aside>

<main class="main">
  <div class="page-header">
    <h1>Welcome back, <%= user.name.split(' ')[0] %></h1>
    <p>Here's your placement preparation overview</p>
  </div>

  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon blue"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
      <div class="stat-value"><%= (user.careerGoals||[]).length + (user.customGoals||[]).length %></div>
      <div class="stat-label">Career Goals</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg></div>
      <div class="stat-value"><%= (user.skills||[]).length %></div>
      <div class="stat-label">Skills Tracked</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon purple"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg></div>
      <div class="stat-value"><%= user.academic && user.academic.year ? user.academic.year : '—' %></div>
      <div class="stat-label">Academic Year</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon orange"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg></div>
      <div class="stat-value" style="font-size:16px;text-transform:capitalize"><%= user.targetCompanyType || 'Product' %></div>
      <div class="stat-label">Target Company</div>
    </div>
  </div>

  <div class="content-grid">
    <div>
      <div class="card">
        <div class="card-header"><span class="card-title">Preparation Tools</span></div>
        <div class="card-body">
          <div class="feature-grid">
            <% const hasRoadmap = (user.careerGoals && user.careerGoals.length > 0); %>

            <!-- Card 1: View Roadmap (primary, always visible) -->
            <a href="/roadmap" class="feature-card primary-action" style="<%= !hasRoadmap ? 'opacity:0.5;pointer-events:none;' : '' %>">
              <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></div>
              <div class="feature-card-title">View Roadmap</div>
              <div class="feature-card-desc"><%= hasRoadmap ? 'Continue your progress' : 'Generate a roadmap first' %></div>
            </a>

            <!-- Cards 2–5: fixed tools -->
            <a href="/builder" class="feature-card">
              <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/></svg></div>
              <div class="feature-card-title">Resume Builder</div>
              <div class="feature-card-desc">Create and optimize your resume</div>
            </a>
            <a href="/resume" class="feature-card">
              <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></div>
              <div class="feature-card-title">ATS Analyzer</div>
              <div class="feature-card-desc">Improve your resume score</div>
            </a>
            <a href="/api/interview/setup" class="feature-card">
              <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg></div>
              <div class="feature-card-title">AI Interview</div>
              <div class="feature-card-desc">Practice real scenarios</div>
            </a>
            <a href="/activity/activity-dashboard" class="feature-card">
              <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
              <div class="feature-card-title">DSA Dashboard</div>
              <div class="feature-card-desc">Track coding consistency</div>
            </a>

            <!-- Card 6: Generate Roadmap (always visible) -->
            <form action="/generate-roadmap<%= hasRoadmap ? '?force=true' : '' %>" method="POST" class="roadmap-form" style="display:contents">
              <button type="submit" class="feature-card" onclick="<%= hasRoadmap ? 'handleReset(event)' : 'handleGenerate(event)' %>" style="border:1.5px solid var(--gray-200);background:none;text-align:left;width:100%;cursor:pointer;font-family:inherit">
                <div class="fc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg></div>
                <div class="feature-card-title">Generate Roadmap</div>
                <div class="feature-card-desc"><%= hasRoadmap ? 'Reset and regenerate' : 'Start your AI plan' %></div>
              </button>
            </form>

          </div>
        </div>
      </div>
      <div class="tip-card">
        <div class="tip-card-title">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          Pro Tip
        </div>
        <p>Follow your roadmap step-by-step and complete subtopics before moving on. Consistency beats intensity every time.</p>
      </div>
    </div>

    <div style="display:flex;flex-direction:column;gap:20px;">
      <div class="card">
        <div class="card-header">
          <span class="card-title">Career Goals</span>
          <a href="/profile" style="font-size:12px;color:var(--blue);text-decoration:none;font-weight:600;">Edit</a>
        </div>
        <div class="card-body">
          <% const allGoals = [...(user.careerGoals||[]),...(user.customGoals||[])]; %>
          <% if (allGoals.length > 0) { %>
            <% allGoals.forEach(goal => { %><span class="goal-tag"><%= goal %></span><% }) %>
          <% } else { %>
            <div class="empty-state">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <p>No goals added yet.<br/><a href="/profile" style="color:var(--blue);font-weight:600;">Add goals</a></p>
            </div>
          <% } %>
        </div>
      </div>
      <div class="card">
        <div class="card-header">
          <span class="card-title">Your Skills</span>
          <a href="/profile" style="font-size:12px;color:var(--blue);text-decoration:none;font-weight:600;">Edit</a>
        </div>
        <div class="card-body">
          <% if (user.skills && user.skills.length > 0) { %>
            <% user.skills.slice(0,6).forEach(skill => { %>
              <div class="skill-item">
                <span class="skill-name"><%= skill.name %></span>
                <span class="skill-badge <%= skill.level %>"><%= skill.level %></span>
              </div>
            <% }) %>
            <% if (user.skills.length > 6) { %><div style="font-size:12px;color:var(--gray-400);margin-top:10px;text-align:center;">+<%= user.skills.length - 6 %> more skills</div><% } %>
          <% } else { %>
            <div class="empty-state">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <p>No skills added yet.<br/><a href="/profile" style="color:var(--blue);font-weight:600;">Add skills</a></p>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</main>

<!-- ROADMAP GENERATION LOADER -->
<div id="loaderOverlay">
  <div class="loader-scene">
    <div class="loader-card">
      <!-- Animated brain/AI icon -->
      <div class="loader-icon-wrap">
        <div class="loader-ring loader-ring-1"></div>
        <div class="loader-ring loader-ring-2"></div>
        <div class="loader-ring loader-ring-3"></div>
        <div class="loader-core">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/>
          </svg>
        </div>
      </div>

      <div class="loader-title">Building your roadmap</div>
      <div class="loader-sub">Our AI is analyzing your profile and crafting a personalized learning path</div>

      <!-- Animated steps -->
      <div class="loader-steps">
        <div class="loader-step" id="ls1">
          <div class="ls-dot"></div>
          <span>Analyzing your skills and goals</span>
        </div>
        <div class="loader-step" id="ls2">
          <div class="ls-dot"></div>
          <span>Mapping learning phases</span>
        </div>
        <div class="loader-step" id="ls3">
          <div class="ls-dot"></div>
          <span>Generating subtopics and resources</span>
        </div>
        <div class="loader-step" id="ls4">
          <div class="ls-dot"></div>
          <span>Finalizing your roadmap</span>
        </div>
      </div>

      <!-- Progress bar -->
      <div class="loader-progress-track">
        <div class="loader-progress-fill" id="loaderProgress"></div>
      </div>
      <div class="loader-progress-label" id="loaderProgressLabel">0%</div>
    </div>
  </div>
</div>

<style>
#loaderOverlay {
  position: fixed; inset: 0;
  background: rgba(15,23,42,0.7);
  display: none; justify-content: center; align-items: center;
  z-index: 9999; backdrop-filter: blur(8px);
}
.loader-scene { animation: sceneIn 0.4s cubic-bezier(0.16,1,0.3,1) both; }
@keyframes sceneIn { from{opacity:0;transform:scale(0.92)} to{opacity:1;transform:scale(1)} }

.loader-card {
  background: white; border-radius: 24px;
  padding: 48px 44px; width: 440px; max-width: calc(100vw - 40px);
  text-align: center; box-shadow: 0 32px 80px rgba(0,0,0,0.3);
}

/* Rings */
.loader-icon-wrap {
  position: relative; width: 100px; height: 100px;
  margin: 0 auto 28px; display: flex; align-items: center; justify-content: center;
}
.loader-ring {
  position: absolute; border-radius: 50%; border: 2px solid transparent;
}
.loader-ring-1 {
  width: 100px; height: 100px;
  border-top-color: #2563eb; border-right-color: #2563eb;
  animation: spin 1.2s linear infinite;
}
.loader-ring-2 {
  width: 76px; height: 76px;
  border-bottom-color: #3b82f6; border-left-color: #3b82f6;
  animation: spin 1.8s linear infinite reverse;
}
.loader-ring-3 {
  width: 54px; height: 54px;
  border-top-color: #93c5fd; border-right-color: #93c5fd;
  animation: spin 2.4s linear infinite;
}
.loader-core {
  width: 40px; height: 40px; background: #eff6ff;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  animation: pulse 2s ease-in-out infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
@keyframes pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.1)} }

.loader-title { font-size: 20px; font-weight: 800; color: #1e293b; margin-bottom: 8px; letter-spacing: -0.3px; }
.loader-sub { font-size: 13px; color: #64748b; line-height: 1.6; margin-bottom: 28px; }

/* Steps */
.loader-steps { text-align: left; margin-bottom: 24px; display: flex; flex-direction: column; gap: 10px; }
.loader-step {
  display: flex; align-items: center; gap: 12px;
  font-size: 13px; color: #94a3b8; font-weight: 500;
  transition: color 0.4s;
}
.loader-step.active { color: #1e293b; }
.loader-step.done { color: #16a34a; }
.ls-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: #e2e8f0; flex-shrink: 0; transition: background 0.4s;
}
.loader-step.active .ls-dot { background: #2563eb; animation: dotPulse 1s ease-in-out infinite; }
.loader-step.done .ls-dot { background: #16a34a; animation: none; }
@keyframes dotPulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.5)} }

/* Progress */
.loader-progress-track {
  height: 6px; background: #e2e8f0; border-radius: 10px; overflow: hidden; margin-bottom: 8px;
}
.loader-progress-fill {
  height: 100%; width: 0%; border-radius: 10px;
  background: linear-gradient(90deg, #2563eb, #3b82f6);
  transition: width 0.6s ease;
}
.loader-progress-label { font-size: 12px; color: #94a3b8; font-weight: 600; }
</style>

<script>
  const hamburger = document.getElementById('hamburgerBtn');
  const sidebar = document.getElementById('sidebar');
  const overlay = document.getElementById('sidebarOverlay');
  hamburger.addEventListener('click', () => { sidebar.classList.toggle('open'); overlay.classList.toggle('open'); });
  overlay.addEventListener('click', () => { sidebar.classList.remove('open'); overlay.classList.remove('open'); });

  function showLoader() {
    document.getElementById('loaderOverlay').style.display = 'flex';
    animateLoader();
  }

  function animateLoader() {
    const steps = [
      { id: 'ls1', delay: 0, progress: 20 },
      { id: 'ls2', delay: 8000, progress: 45 },
      { id: 'ls3', delay: 20000, progress: 70 },
      { id: 'ls4', delay: 40000, progress: 90 },
    ];
    const fill = document.getElementById('loaderProgress');
    const label = document.getElementById('loaderProgressLabel');

    steps.forEach((s, i) => {
      setTimeout(() => {
        if (i > 0) {
          const prev = document.getElementById(steps[i-1].id);
          prev.classList.remove('active'); prev.classList.add('done');
          prev.querySelector('.ls-dot').innerHTML = '';
        }
        const el = document.getElementById(s.id);
        el.classList.add('active');
        fill.style.width = s.progress + '%';
        label.textContent = s.progress + '%';
      }, s.delay);
    });
  }

  function handleGenerate(e) {
    e.preventDefault(); showLoader(); e.target.closest('form').submit();
  }
  function handleReset(e) {
    e.preventDefault();
    if (confirm('This will DELETE your current roadmap and all progress. Continue?')) {
      showLoader(); e.target.closest('form').submit();
    }
  }
</script>
</body>
</html>
