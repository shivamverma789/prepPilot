    <div class="resource-grid">
      <div class="resource-card">
        <div class="resource-card-top"><div><div class="resource-name">LeetCode 75</div></div><div class="resource-icon" style="background:#fff7ed"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div></div>
        <div class="resource-desc">Top 75 interview questions — the fastest way to prepare for FAANG interviews.</div>
