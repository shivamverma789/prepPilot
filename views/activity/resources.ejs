      </div>
      <div class="resource-card">
        <div class="resource-card-top"><div><div class="resource-name">TakeUForward (Striver)</div></div><div class="resource-icon" style="background:#fce7f3"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#db2777" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg></div></div>
