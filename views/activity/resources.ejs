<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>DSA Resources</title>

    <style>
        body {
            font-family: 'Segoe UI', sans-serif;
            background: #0d1117;
            color: #e6edf3;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1100px;
            margin: auto;
            padding: 30px;
        }

        h1 {
            text-align: center;
            margin-bottom: 40px;
        }

        h2 {
            margin-top: 40px;
            margin-bottom: 15px;
            color: #58a6ff;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
        }

        .card {
            background: #161b22;
            padding: 20px;
            border-radius: 10px;
            transition: 0.2s ease;
            border: 1px solid #30363d;
        }

        .card:hover {
            transform: translateY(-5px);
            border-color: #58a6ff;
            box-shadow: 0 0 10px rgba(88,166,255,0.2);
        }

        .title {
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 10px;
        }

        .desc {
            font-size: 14px;
            color: #8b949e;
            margin-bottom: 15px;
        }

        .btn {
            display: inline-block;
            padding: 8px 12px;
            background: #238636;
            color: white;
            text-decoration: none;
            border-radius: 6px;
            font-size: 14px;
        }

        .btn:hover {
            background: #2ea043;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>📚 DSA Resource Hub</h1>

    <!-- Beginner -->
    <h2>🚀 Beginner to Intermediate</h2>

    <div class="grid">

        <div class="card">
            <div class="title">Striver A2Z Sheet</div>
            <div class="desc">Step-by-step structured DSA roadmap</div>
            <a href="https://takeuforward.org/strivers-a2z-dsa-course/strivers-a2z-dsa-course-sheet-2/" target="_blank" class="btn">Open</a>
        </div>

        <div class="card">
            <div class="title">Love Babbar 450</div>
            <div class="desc">450 curated problems for placements</div>
            <a href="https://450dsa.com/" target="_blank" class="btn">Open</a>
        </div>

    </div>

    <!-- Practice -->
    <h2>💡 Practice Lists</h2>

    <div class="grid">

        <div class="card">
            <div class="title">LeetCode 75</div>
            <div class="desc">Top interview questions (fast prep)</div>
            <a href="https://leetcode.com/studyplan/leetcode-75/" target="_blank" class="btn">Open</a>
        </div>

        <div class="card">
            <div class="title">NeetCode 75</div>
            <div class="desc">Best explained curated problems</div>
            <a href="https://neetcode.io/practice" target="_blank" class="btn">Open</a>
        </div>

    </div>

    <!-- Advanced -->
    <h2>🔥 Advanced / Competitive</h2>

    <div class="grid">

        <div class="card">
            <div class="title">Striver SDE Sheet</div>
            <div class="desc">Deep interview preparation</div>
            <a href="https://takeuforward.org/interviews/strivers-sde-sheet-top-coding-interview-problems/" target="_blank" class="btn">Open</a>
        </div>

        <div class="card">
            <div class="title">Codeforces Problems</div>
            <div class="desc">Competitive programming practice</div>
            <a href="https://codeforces.com/problemset" target="_blank" class="btn">Open</a>
        </div>

    </div>

    <!-- Learning -->
    <h2>🎥 Learning Playlists</h2>

    <div class="grid">

        <div class="card">
            <div class="title">CodeHelp - by Babbar</div>
            <div class="desc">Complete C++ Placement DSA Course</div>
            <a href="https://www.youtube.com/playlist?list=PLDzeHZWIZsTryvtXdMr6rPh4IDexB5NIA" target="_blank" class="btn">Watch</a>
        </div>

        <div class="card">
            <div class="title">TakeUForward (Striver)</div>
            <div class="desc">Structured DSA explanations</div>
            <a href="https://www.youtube.com/playlist?list=PLgUwDviBIf0oF6QL8m22w1hIDC1vJ_BHz" target="_blank" class="btn">Watch</a>
        </div>

    </div>

</div>

</body>
</html>