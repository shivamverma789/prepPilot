      </div>
      <div class="resource-card">
        <div class="resource-card-top"><div><div class="resource-name">Love Babbar 450</div></div><div class="resource-icon" style="background:#f0fdf4"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg></div></div>
