<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Activity Profile Setup — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue:#2563eb; --blue-dark:#1d4ed8; --blue-mid:#3b82f6;
      --blue-light:#eff6ff; --blue-pale:#dbeafe;
      --white:#fff; --gray-50:#f8fafc; --gray-100:#f1f5f9;
      --gray-200:#e2e8f0; --gray-400:#94a3b8; --gray-500:#64748b;
      --gray-600:#475569; --gray-700:#334155; --gray-800:#1e293b; --gray-900:#0f172a;
      --sidebar-w:260px; --navbar-h:64px; --radius:14px;
      --shadow-sm:0 1px 3px rgba(0,0,0,0.06);
    }
    body { font-family:'Inter',sans-serif; background:var(--gray-50); color:var(--gray-800); min-height:100vh; }
    .navbar { position:fixed; top:0; left:0; right:0; height:var(--navbar-h); background:var(--white); border-bottom:1px solid var(--gray-200); display:flex; align-items:center; padding:0 24px; z-index:100; gap:16px; }
    .nav-brand { display:flex; align-items:center; gap:10px; font-size:18px; font-weight:800; color:var(--gray-900); text-decoration:none; letter-spacing:-0.5px; }
    .nav-brand-icon { width:36px; height:36px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .nav-spacer { flex:1; }
    .nav-btn { padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Inter',sans-serif; cursor:pointer; border:none; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all 0.15s; }
    .nav-btn-ghost { background:transparent; color:var(--gray-600); border:1.5px solid var(--gray-200); }
    .nav-btn-ghost:hover { background:var(--gray-100); }
    .hamburger { display:none; background:none; border:none; cursor:pointer; padding:6px; border-radius:8px; color:var(--gray-600); }
    .sidebar { position:fixed; top:var(--navbar-h); left:0; width:var(--sidebar-w); height:calc(100vh - var(--navbar-h)); background:var(--white); border-right:1px solid var(--gray-200); padding:24px 16px; overflow-y:auto; z-index:90; transition:transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .sidebar-section { margin-bottom:28px; }
    .sidebar-label { font-size:10px; font-weight:700; color:var(--gray-400); letter-spacing:1px; text-transform:uppercase; padding:0 12px; margin-bottom:8px; }
    .sidebar-link { display:flex; align-items:center; gap:12px; padding:10px 12px; border-radius:10px; font-size:14px; font-weight:500; color:var(--gray-600); text-decoration:none; transition:all 0.15s; margin-bottom:2px; }
    .sidebar-link:hover { background:var(--gray-100); color:var(--gray-800); }
    .sidebar-link.active { background:var(--blue-light); color:var(--blue); font-weight:600; }
    .s-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; background:var(--gray-100); }
    .sidebar-link.active .s-icon { background:var(--blue-pale); }
    .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:89; }
    .main { margin-left:var(--sidebar-w); margin-top:var(--navbar-h); padding:32px; display:flex; justify-content:center; }
    .content-wrap { width:100%; max-width:600px; animation:fadeUp 0.4s ease both; }
    .page-header { margin-bottom:28px; }
    .page-header h1 { font-size:26px; font-weight:800; color:var(--gray-900); letter-spacing:-0.5px; }
    .page-header p { font-size:14px; color:var(--gray-500); margin-top:4px; }
    .platform-card { background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-200); padding:18px 20px; margin-bottom:12px; display:flex; align-items:center; gap:16px; box-shadow:var(--shadow-sm); transition:box-shadow 0.2s; }
    .platform-card:hover { box-shadow:0 4px 16px rgba(0,0,0,0.07); }
    .platform-icon { width:40px; height:40px; border-radius:10px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .platform-info { flex:1; min-width:0; }
    .platform-name { font-size:14px; font-weight:700; color:var(--gray-800); margin-bottom:2px; }
    .platform-hint { font-size:12px; color:var(--gray-400); }
    .platform-input { width:100%; padding:9px 12px; border:1.5px solid var(--gray-200); border-radius:8px; font-size:14px; font-family:'Inter',sans-serif; color:var(--gray-800); background:var(--gray-50); outline:none; transition:border-color 0.2s,box-shadow 0.2s; }
    .platform-input:focus { border-color:var(--blue); background:var(--white); box-shadow:0 0 0 3px rgba(37,99,235,0.08); }
    .btn-primary { width:100%; padding:13px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); color:white; border:none; border-radius:10px; font-size:15px; font-weight:700; font-family:'Inter',sans-serif; cursor:pointer; transition:all 0.15s; box-shadow:0 4px 14px rgba(37,99,235,0.3); margin-top:8px; }
    .btn-primary:hover { transform:translateY(-1px); box-shadow:0 6px 20px rgba(37,99,235,0.4); }
    .info-note { background:var(--blue-light); border:1px solid var(--blue-pale); border-radius:10px; padding:12px 16px; font-size:13px; color:var(--blue-dark); margin-bottom:20px; display:flex; align-items:flex-start; gap:8px; line-height:1.5; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @media(max-width:768px) { .hamburger{display:flex} .sidebar{transform:translateX(-100%)} .sidebar.open{transform:translateX(0);box-shadow:4px 0 24px rgba(0,0,0,0.12)} .sidebar-overlay.open{display:block} .main{margin-left:0;padding:20px 16px} .platform-card{flex-wrap:wrap} }
  </style>
</head>
<body>

<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/></svg></button>
  <a href="/dashboard" class="nav-brand">
    <div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    PrepPilot
  </a>
  <div class="nav-spacer"></div>
  <a href="/activity/activity-dashboard" class="nav-btn nav-btn-ghost">Back to Dashboard</a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard</a>
    <a href="/activity/activity-dashboard" class="sidebar-link active"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span> DSA Activity</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> Profile</a>
    <a href="/logout" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="content-wrap">
    <div class="page-header">
      <h1>Activity Profile Setup</h1>
      <p>Connect your coding platforms to start tracking your activity</p>
    </div>

    <div class="info-note">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:1px"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      After saving, go back to the dashboard and click "Sync All" to fetch your latest activity data.
    </div>

    <form action="/activity/activity-profile" method="POST">

      <div class="platform-card">
        <div class="platform-icon" style="background:#fff7ed"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f97316" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg></div>
        <div class="platform-info"><div class="platform-name">LeetCode</div><div class="platform-hint">e.g. john_doe</div></div>
        <div style="width:180px;flex-shrink:0;"><input type="text" name="leetcodeUsername" class="platform-input" placeholder="Username" value="<%= userPlatforms?.leetcodeUsername || '' %>"/></div>
      </div>

      <div class="platform-card">
        <div class="platform-icon" style="background:#f1f5f9"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1e293b" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg></div>
        <div class="platform-info"><div class="platform-name">GitHub</div><div class="platform-hint">e.g. shivam-verma</div></div>
        <div style="width:180px;flex-shrink:0;"><input type="text" name="githubUsername" class="platform-input" placeholder="Username" value="<%= userPlatforms?.githubUsername || '' %>"/></div>
      </div>

      <div class="platform-card">
        <div class="platform-icon" style="background:#eff6ff"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3b82f6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
        <div class="platform-info"><div class="platform-name">Codeforces</div><div class="platform-hint">e.g. tourist</div></div>
        <div style="width:180px;flex-shrink:0;"><input type="text" name="codeforcesHandle" class="platform-input" placeholder="Handle" value="<%= userPlatforms?.codeforcesHandle || '' %>"/></div>
      </div>

      <div class="platform-card">
        <div class="platform-icon" style="background:#ecfdf5"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 22 8.5 22 15.5 12 22 2 15.5 2 8.5 12 2"/></svg></div>
        <div class="platform-info"><div class="platform-name">HackerRank</div><div class="platform-hint">e.g. shivam_dev</div></div>
        <div style="width:180px;flex-shrink:0;"><input type="text" name="hackerrankUsername" class="platform-input" placeholder="Username" value="<%= userPlatforms?.hackerrankUsername || '' %>"/></div>
      </div>

      <div class="platform-card">
        <div class="platform-icon" style="background:#fef3c7"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#92400e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="8" y1="12" x2="16" y2="12"/><line x1="12" y1="8" x2="12" y2="16"/></svg></div>
        <div class="platform-info"><div class="platform-name">CodeChef</div><div class="platform-hint">e.g. shivam_01</div></div>
        <div style="width:180px;flex-shrink:0;"><input type="text" name="codechefUsername" class="platform-input" placeholder="Username" value="<%= userPlatforms?.codechefUsername || '' %>"/></div>
      </div>

      <button type="submit" class="btn-primary">Save and Continue</button>
    </form>
  </div>
</main>

<script>
  document.getElementById('hamburgerBtn').addEventListener('click', () => { document.getElementById('sidebar').classList.toggle('open'); document.getElementById('sidebarOverlay').classList.toggle('open'); });
  document.getElementById('sidebarOverlay').addEventListener('click', () => { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); });
</script>
</body>
</html>
