<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>DSA Activity — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --blue:#2563eb; --blue-dark:#1d4ed8; --blue-mid:#3b82f6;
      --blue-light:#eff6ff; --blue-pale:#dbeafe;
      --white:#fff; --gray-50:#f8fafc; --gray-100:#f1f5f9;
      --gray-200:#e2e8f0; --gray-300:#cbd5e1; --gray-400:#94a3b8;
      --gray-500:#64748b; --gray-600:#475569; --gray-700:#334155;
      --gray-800:#1e293b; --gray-900:#0f172a;
      --green:#16a34a; --green-light:#dcfce7;
      --sidebar-w:260px; --navbar-h:64px; --radius:14px;
      --shadow-sm:0 1px 3px rgba(0,0,0,0.06); --shadow:0 4px 16px rgba(0,0,0,0.07);
    }
    body { font-family:'Inter',sans-serif; background:var(--gray-50); color:var(--gray-800); min-height:100vh; }
    .navbar { position:fixed; top:0; left:0; right:0; height:var(--navbar-h); background:var(--white); border-bottom:1px solid var(--gray-200); display:flex; align-items:center; padding:0 24px; z-index:100; gap:16px; }
    .nav-brand { display:flex; align-items:center; gap:10px; font-size:18px; font-weight:800; color:var(--gray-900); text-decoration:none; letter-spacing:-0.5px; }
    .nav-brand-icon { width:36px; height:36px; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); border-radius:10px; display:flex; align-items:center; justify-content:center; }
    .nav-spacer { flex:1; }
    .nav-btn { padding:8px 16px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Inter',sans-serif; cursor:pointer; border:none; text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all 0.15s; }
    .nav-btn-ghost { background:transparent; color:var(--gray-600); border:1.5px solid var(--gray-200); }
    .nav-btn-ghost:hover { background:var(--gray-100); }
    .nav-btn-primary { background:linear-gradient(135deg,var(--blue),var(--blue-mid)); color:white; box-shadow:0 2px 8px rgba(37,99,235,0.3); }
    .nav-btn-primary:hover { transform:translateY(-1px); }
    .hamburger { display:none; background:none; border:none; cursor:pointer; padding:6px; border-radius:8px; color:var(--gray-600); }
    .sidebar { position:fixed; top:var(--navbar-h); left:0; width:var(--sidebar-w); height:calc(100vh - var(--navbar-h)); background:var(--white); border-right:1px solid var(--gray-200); padding:24px 16px; overflow-y:auto; z-index:90; transition:transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .sidebar-section { margin-bottom:28px; }
    .sidebar-label { font-size:10px; font-weight:700; color:var(--gray-400); letter-spacing:1px; text-transform:uppercase; padding:0 12px; margin-bottom:8px; }
    .sidebar-link { display:flex; align-items:center; gap:12px; padding:10px 12px; border-radius:10px; font-size:14px; font-weight:500; color:var(--gray-600); text-decoration:none; transition:all 0.15s; margin-bottom:2px; }
    .sidebar-link:hover { background:var(--gray-100); color:var(--gray-800); }
    .sidebar-link.active { background:var(--blue-light); color:var(--blue); font-weight:600; }
    .s-icon { width:32px; height:32px; border-radius:8px; display:flex; align-items:center; justify-content:center; flex-shrink:0; background:var(--gray-100); }
    .sidebar-link.active .s-icon { background:var(--blue-pale); }
    .sidebar-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.4); z-index:89; }
    .main { margin-left:var(--sidebar-w); margin-top:var(--navbar-h); padding:32px; }
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:28px; flex-wrap:wrap; gap:12px; animation:fadeUp 0.4s ease both; }
    .page-header h1 { font-size:26px; font-weight:800; color:var(--gray-900); letter-spacing:-0.5px; }
    .page-header p { font-size:14px; color:var(--gray-500); margin-top:4px; }
    /* STATS */
    .stats-row { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; margin-bottom:24px; }
    .stat-card { background:var(--white); border-radius:var(--radius); padding:18px 20px; border:1px solid var(--gray-200); box-shadow:var(--shadow-sm); animation:fadeUp 0.4s ease both; transition:transform 0.2s,box-shadow 0.2s; }
    .stat-card:hover { transform:translateY(-2px); box-shadow:var(--shadow); }
    .stat-card:nth-child(1){animation-delay:0.05s} .stat-card:nth-child(2){animation-delay:0.1s} .stat-card:nth-child(3){animation-delay:0.15s} .stat-card:nth-child(4){animation-delay:0.2s} .stat-card:nth-child(5){animation-delay:0.25s}
    .stat-icon { width:36px; height:36px; border-radius:9px; display:flex; align-items:center; justify-content:center; margin-bottom:10px; }
    .stat-icon.blue{background:var(--blue-light)} .stat-icon.green{background:#f0fdf4} .stat-icon.orange{background:#fff7ed} .stat-icon.purple{background:#faf5ff} .stat-icon.red{background:#fef2f2}
    .stat-value { font-size:22px; font-weight:800; color:var(--gray-900); letter-spacing:-0.5px; }
    .stat-label { font-size:12px; color:var(--gray-500); margin-top:2px; }
    /* ACTIONS BAR */
    .actions-bar { display:flex; align-items:center; gap:10px; margin-bottom:24px; flex-wrap:wrap; animation:fadeUp 0.4s 0.2s ease both; }
    .platform-filter { padding:8px 14px; border-radius:8px; border:1.5px solid var(--gray-200); font-size:13px; font-family:'Inter',sans-serif; color:var(--gray-700); background:var(--white); outline:none; cursor:pointer; transition:border-color 0.15s; }
    .platform-filter:focus { border-color:var(--blue); }
    .sync-btn { padding:8px 14px; border-radius:8px; font-size:13px; font-weight:600; font-family:'Inter',sans-serif; cursor:pointer; border:1.5px solid var(--gray-200); background:var(--white); color:var(--gray-600); text-decoration:none; display:inline-flex; align-items:center; gap:6px; transition:all 0.15s; }
    .sync-btn:hover { border-color:var(--blue); color:var(--blue); background:var(--blue-light); }
    .sync-btn.primary { background:linear-gradient(135deg,var(--blue),var(--blue-mid)); color:white; border-color:transparent; box-shadow:0 2px 8px rgba(37,99,235,0.3); }
    .sync-btn.primary:hover { transform:translateY(-1px); box-shadow:0 4px 14px rgba(37,99,235,0.4); color:white; background:linear-gradient(135deg,var(--blue),var(--blue-mid)); }
    .timer-badge { font-size:12px; color:var(--gray-400); font-weight:500; margin-left:auto; }
    /* HEATMAP */
    .card { background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-200); box-shadow:var(--shadow-sm); padding:24px; margin-bottom:20px; animation:fadeUp 0.4s ease both; }
    .card-title { font-size:15px; font-weight:700; color:var(--gray-800); margin-bottom:18px; display:flex; align-items:center; gap:8px; }
    .heatmap-scroll { overflow-x:auto; padding-bottom:8px; }
    .heatmap-inner { display:flex; gap:16px; min-width:max-content; }
    .heatmap-month { display:flex; flex-direction:column; }
    .heatmap-month-name { font-size:11px; font-weight:600; color:var(--gray-400); margin-bottom:6px; letter-spacing:0.3px; }
    .heatmap-weeks { display:flex; gap:3px; }
    .heatmap-col { display:flex; flex-direction:column; gap:3px; }
    .heatmap-day { width:13px; height:13px; border-radius:3px; cursor:pointer; transition:transform 0.1s; }
    .heatmap-day:hover { transform:scale(1.3); }
    .heatmap-legend { display:flex; align-items:center; gap:6px; margin-top:14px; font-size:11px; color:var(--gray-400); }
    .legend-box { width:13px; height:13px; border-radius:3px; }
    /* PLATFORM CARDS */
    .platform-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px; }
    .platform-card { background:var(--white); border-radius:var(--radius); border:1px solid var(--gray-200); padding:20px; box-shadow:var(--shadow-sm); transition:transform 0.2s,box-shadow 0.2s; }
    .platform-card:hover { transform:translateY(-2px); box-shadow:var(--shadow); }
    .platform-card-header { display:flex; align-items:center; gap:10px; margin-bottom:14px; }
    .platform-card-icon { width:36px; height:36px; border-radius:9px; display:flex; align-items:center; justify-content:center; flex-shrink:0; }
    .platform-card-name { font-size:14px; font-weight:700; color:var(--gray-800); }
    .platform-stat { display:flex; justify-content:space-between; align-items:center; padding:6px 0; border-bottom:1px solid var(--gray-100); font-size:13px; }
    .platform-stat:last-child { border-bottom:none; }
    .platform-stat-label { color:var(--gray-500); }
    .platform-stat-value { font-weight:700; color:var(--gray-800); }
    /* BREAKDOWN */
    .breakdown-row { display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--gray-100); }
    .breakdown-row:last-child { border-bottom:none; }
    .breakdown-label { font-size:13px; color:var(--gray-600); width:100px; flex-shrink:0; }
    .breakdown-bar-wrap { flex:1; height:8px; background:var(--gray-100); border-radius:10px; overflow:hidden; }
    .breakdown-bar { height:100%; border-radius:10px; background:linear-gradient(90deg,var(--blue),var(--blue-mid)); transition:width 1s ease; }
    .breakdown-val { font-size:13px; font-weight:700; color:var(--gray-800); width:40px; text-align:right; flex-shrink:0; }
    /* TOOLTIP */
    #tooltip { position:fixed; background:var(--gray-900); color:white; padding:6px 10px; border-radius:8px; font-size:12px; font-weight:500; pointer-events:none; display:none; z-index:999; white-space:nowrap; }
    @keyframes fadeUp { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
    @media(max-width:1200px){.stats-row{grid-template-columns:repeat(3,1fr)}}
    @media(max-width:900px){.stats-row{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){.hamburger{display:flex}.sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0);box-shadow:4px 0 24px rgba(0,0,0,0.12)}.sidebar-overlay.open{display:block}.main{margin-left:0;padding:20px 16px}.stats-row{grid-template-columns:repeat(2,1fr)}}
  </style>
</head>
<body>

<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/></svg></button>
  <a href="/dashboard" class="nav-brand">
    <div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    PrepPilot
  </a>
  <div class="nav-spacer"></div>
  <a href="/activity/activity-profile" class="nav-btn nav-btn-ghost">Setup Profiles</a>
  <a href="/activity/activity-sync/all" class="nav-btn nav-btn-primary" id="syncAllBtn">Sync All</a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard</a>
    <a href="/roadmap" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> Roadmap</a>
    <a href="/activity/activity-dashboard" class="sidebar-link active"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span> DSA Activity</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <a href="/builder" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span> Resume Builder</a>
    <a href="/resume" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span> ATS Analyzer</a>
    <a href="/api/interview/setup" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/></svg></span> AI Interview</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> Profile</a>
    <a href="/logout" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="page-header">
    <div>
      <h1>DSA Activity</h1>
      <p>Track your coding consistency across all platforms</p>
    </div>
  </div>

  <!-- STATS -->
  <div class="stats-row">
    <div class="stat-card">
      <div class="stat-icon blue"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/></svg></div>
      <div class="stat-value"><%= totalSolved %></div>
      <div class="stat-label">Problems Solved</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon green"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
      <div class="stat-value"><%= activeDays %></div>
      <div class="stat-label">Active Days</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon orange"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></div>
      <div class="stat-value"><%= totalActivity %></div>
      <div class="stat-label">Total Activity</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon red"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg></div>
      <div class="stat-value"><%= currentStreak %></div>
      <div class="stat-label">Current Streak</div>
    </div>
    <div class="stat-card">
      <div class="stat-icon purple"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg></div>
      <div class="stat-value"><%= longestStreak %></div>
      <div class="stat-label">Longest Streak</div>
    </div>
  </div>

  <!-- ACTIONS BAR -->
  <div class="actions-bar">
    <form method="GET" action="/activity/activity-dashboard" style="display:inline;">
      <select name="platform" class="platform-filter" onchange="this.form.submit()">
        <option value="all" <%= selectedPlatform==='all'?'selected':'' %>>All Platforms</option>
        <option value="leetcode" <%= selectedPlatform==='leetcode'?'selected':'' %>>LeetCode</option>
        <option value="github" <%= selectedPlatform==='github'?'selected':'' %>>GitHub</option>
        <option value="codeforces" <%= selectedPlatform==='codeforces'?'selected':'' %>>Codeforces</option>
        <option value="codechef" <%= selectedPlatform==='codechef'?'selected':'' %>>CodeChef</option>
      </select>
    </form>
    <a href="/activity/activity-sync/leetcode" class="sync-btn">Sync LeetCode</a>
    <a href="/activity/activity-sync/github" class="sync-btn">Sync GitHub</a>
    <a href="/activity/activity-sync/codeforces" class="sync-btn">Sync CF</a>
    <a href="/activity/activity-sync/codechef" class="sync-btn">Sync CodeChef</a>
    <span class="timer-badge" id="timer">Next refresh in: --</span>
  </div>

  <!-- HEATMAP -->
  <div class="card" style="animation-delay:0.3s">
    <div class="card-title">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      Activity Heatmap — Last 365 Days
    </div>
    <div class="heatmap-scroll">
      <div class="heatmap-inner">
        <% months.forEach(month => { %>
          <div class="heatmap-month">
            <div class="heatmap-month-name"><%= month.name %></div>
            <div class="heatmap-weeks">
              <% month.weeks.forEach(week => { %>
                <div class="heatmap-col">
                  <% week.forEach(day => { %>
                    <% const count = day ? day.count : 0; %>
                    <% const color = !day || count === 0 ? '#e2e8f0' : count < 3 ? '#bfdbfe' : count < 6 ? '#60a5fa' : count < 10 ? '#2563eb' : '#1d4ed8'; %>
                    <div class="heatmap-day"
                      style="background:<%= color %>"
                      data-date="<%= day ? day.date : '' %>"
                      data-count="<%= count %>">
                    </div>
                  <% }) %>
                </div>
              <% }) %>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
    <div class="heatmap-legend">
      <span>Less</span>
      <div class="legend-box" style="background:#e2e8f0"></div>
      <div class="legend-box" style="background:#bfdbfe"></div>
      <div class="legend-box" style="background:#60a5fa"></div>
      <div class="legend-box" style="background:#2563eb"></div>
      <div class="legend-box" style="background:#1d4ed8"></div>
      <span>More</span>
    </div>
  </div>

  <!-- BREAKDOWN + PLATFORM CARDS -->
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;flex-wrap:wrap;" class="bottom-grid">

    <div class="card" style="animation-delay:0.35s">
      <div class="card-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
        Platform Breakdown
      </div>
      <% const maxSolved = Math.max(solvedBreakdown.leetcode, solvedBreakdown.codechef, solvedBreakdown.codeforces, 1); %>
      <div class="breakdown-row">
        <span class="breakdown-label">LeetCode</span>
        <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round((solvedBreakdown.leetcode/maxSolved)*100) %>%"></div></div>
        <span class="breakdown-val"><%= solvedBreakdown.leetcode %></span>
      </div>
      <div class="breakdown-row">
        <span class="breakdown-label">CodeChef</span>
        <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round((solvedBreakdown.codechef/maxSolved)*100) %>%;background:linear-gradient(90deg,#92400e,#d97706)"></div></div>
        <span class="breakdown-val"><%= solvedBreakdown.codechef %></span>
      </div>
      <div class="breakdown-row">
        <span class="breakdown-label">Codeforces</span>
        <div class="breakdown-bar-wrap"><div class="breakdown-bar" style="width:<%= Math.round((solvedBreakdown.codeforces/maxSolved)*100) %>%;background:linear-gradient(90deg,#7c3aed,#a78bfa)"></div></div>
        <span class="breakdown-val"><%= solvedBreakdown.codeforces %></span>
      </div>
    </div>

    <div class="card" style="animation-delay:0.4s">
      <div class="card-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        Platform Ratings
      </div>
      <div class="platform-stat"><span class="platform-stat-label">CF Rating</span><span class="platform-stat-value"><%= cfRating || '—' %></span></div>
      <div class="platform-stat"><span class="platform-stat-label">CF Max Rating</span><span class="platform-stat-value"><%= cfMaxRating || '—' %></span></div>
      <div class="platform-stat"><span class="platform-stat-label">CF Rank</span><span class="platform-stat-value" style="text-transform:capitalize"><%= cfRank %></span></div>
      <div class="platform-stat"><span class="platform-stat-label">CC Rating</span><span class="platform-stat-value"><%= codechefRating || '—' %></span></div>
      <div class="platform-stat"><span class="platform-stat-label">CC Global Rank</span><span class="platform-stat-value"><%= codechefGlobalRank || '—' %></span></div>
    </div>

  </div>

  <div style="margin-top:16px;animation:fadeUp 0.4s 0.45s ease both;">
    <a href="/activity/resources" class="nav-btn nav-btn-ghost" style="display:inline-flex;">View Resources</a>
  </div>
</main>

<div id="tooltip"></div>

<script>
  document.getElementById('hamburgerBtn').addEventListener('click', () => { document.getElementById('sidebar').classList.toggle('open'); document.getElementById('sidebarOverlay').classList.toggle('open'); });
  document.getElementById('sidebarOverlay').addEventListener('click', () => { document.getElementById('sidebar').classList.remove('open'); document.getElementById('sidebarOverlay').classList.remove('open'); });

  // Heatmap tooltip
  const tooltip = document.getElementById('tooltip');
  document.querySelectorAll('.heatmap-day').forEach(box => {
    box.addEventListener('mouseenter', e => {
      if (!box.dataset.date) return;
      tooltip.textContent = box.dataset.date + ' — ' + box.dataset.count + ' activities';
      tooltip.style.display = 'block';
    });
    box.addEventListener('mousemove', e => {
      tooltip.style.left = (e.clientX + 12) + 'px';
      tooltip.style.top = (e.clientY - 32) + 'px';
    });
    box.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
  });

  // Auto-sync timer
  const REFRESH_INTERVAL = 24 * 60 * 60;
  let lastSync = parseInt(localStorage.getItem('lastSync')) || Math.floor(Date.now() / 1000);
  if (!localStorage.getItem('lastSync')) localStorage.setItem('lastSync', lastSync);
  let hasSynced = false;

  function updateTimer() {
    const now = Math.floor(Date.now() / 1000);
    let remaining = REFRESH_INTERVAL - (now - lastSync);
    if (remaining <= 0 && !hasSynced) {
      hasSynced = true;
      document.getElementById('timer').textContent = 'Syncing...';
      localStorage.setItem('lastSync', now);
      setTimeout(() => { window.location.href = '/activity/activity-sync/all'; }, 800);
      return;
    }
    const h = Math.floor(remaining / 3600);
    const m = Math.floor((remaining % 3600) / 60);
    const s = remaining % 60;
    document.getElementById('timer').textContent = `Next sync in: ${h}h ${m}m ${s}s`;
  }
  setInterval(updateTimer, 1000);
  updateTimer();

  document.getElementById('syncAllBtn').addEventListener('click', () => {
    localStorage.setItem('lastSync', Math.floor(Date.now() / 1000));
  });

  // Animate breakdown bars on load
  window.addEventListener('load', () => {
    document.querySelectorAll('.breakdown-bar').forEach(bar => {
      const w = bar.style.width; bar.style.width = '0';
      setTimeout(() => { bar.style.width = w; }, 300);
    });
  });
</script>
</body>
</html>
