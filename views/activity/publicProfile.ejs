<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="icon" type="image/x-icon" href="/images/favicon/favicon.ico"/>
  <link rel="icon" type="image/png" sizes="96x96" href="/images/favicon/favicon-96x96.png"/>
  <link rel="icon" type="image/svg+xml" href="/images/favicon/favicon.svg"/>
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png"/>
  <link rel="manifest" href="/images/favicon/site.webmanifest"/>
  <title><%= user.username %> — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--blue:#2563eb;--blue-mid:#3b82f6;--blue-light:#eff6ff;--blue-pale:#dbeafe;--white:#fff;--gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;--gray-400:#94a3b8;--gray-500:#64748b;--gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;--gray-900:#0f172a;--radius:14px;--shadow-sm:0 1px 3px rgba(0,0,0,0.06);--shadow:0 4px 16px rgba(0,0,0,0.07)}
    body{font-family:'Inter',sans-serif;background:var(--gray-50);color:var(--gray-800);min-height:100vh}
    .topbar{height:60px;background:var(--white);border-bottom:1px solid var(--gray-200);display:flex;align-items:center;padding:0 32px;gap:12px;position:sticky;top:0;z-index:10}
    .topbar-brand{display:flex;align-items:center;gap:10px;font-size:17px;font-weight:800;color:var(--gray-900);text-decoration:none;letter-spacing:-0.4px}
    .topbar-brand-icon{width:32px;height:32px;background:linear-gradient(135deg,var(--blue),var(--blue-mid));border-radius:9px;display:flex;align-items:center;justify-content:center}
    .topbar-spacer{flex:1}
    .page-body{display:flex;justify-content:center;padding:40px 20px 60px}
    .content-wrap{width:100%;max-width:860px}
    /* PROFILE HERO */
    .profile-hero{background:linear-gradient(135deg,#1d4ed8,var(--blue),var(--blue-mid));border-radius:var(--radius);padding:36px;margin-bottom:20px;color:white;display:flex;align-items:center;gap:24px;flex-wrap:wrap;animation:fadeUp 0.4s ease both}
    .profile-avatar{width:72px;height:72px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:800;flex-shrink:0}
    .profile-info h1{font-size:24px;font-weight:800;margin-bottom:4px}
    .profile-info p{font-size:14px;opacity:0.75}
    .profile-stats{display:flex;gap:28px;margin-top:16px;flex-wrap:wrap}
    .profile-stat-val{font-size:26px;font-weight:800;line-height:1}
    .profile-stat-label{font-size:12px;opacity:0.7;margin-top:2px}
    /* CARD */
    .card{background:var(--white);border-radius:var(--radius);border:1px solid var(--gray-200);padding:24px;margin-bottom:16px;box-shadow:var(--shadow-sm);animation:fadeUp 0.4s ease both}
    .card-title{font-size:15px;font-weight:700;color:var(--gray-800);margin-bottom:18px;display:flex;align-items:center;gap:8px}
    /* HEATMAP */
    .heatmap-scroll{overflow-x:auto;padding-bottom:8px}
    .heatmap-inner{display:flex;gap:16px;min-width:max-content}
    .heatmap-month{display:flex;flex-direction:column}
    .heatmap-month-name{font-size:11px;font-weight:600;color:var(--gray-400);margin-bottom:6px}
    .heatmap-weeks{display:flex;gap:3px}
    .heatmap-col{display:flex;flex-direction:column;gap:3px}
    .heatmap-day{width:13px;height:13px;border-radius:3px}
    .heatmap-legend{display:flex;align-items:center;gap:6px;margin-top:14px;font-size:11px;color:var(--gray-400)}
    .legend-box{width:13px;height:13px;border-radius:3px}
    #tooltip{position:fixed;background:var(--gray-900);color:white;padding:6px 10px;border-radius:8px;font-size:12px;font-weight:500;pointer-events:none;display:none;z-index:999;white-space:nowrap}
    @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:600px){.profile-hero{flex-direction:column}.topbar{padding:0 16px}.page-body{padding:24px 12px 40px}}
  </style>
</head>
<body>
<div class="topbar">
  <a href="/dashboard" class="topbar-brand">
    <div class="topbar-brand-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>
    PrepPilot
  </a>
  <div class="topbar-spacer"></div>
</div>

<div class="page-body">
  <div class="content-wrap">

    <div class="profile-hero">
      <div class="profile-avatar"><%= user.name ? user.name.charAt(0).toUpperCase() : user.username.charAt(0).toUpperCase() %></div>
      <div class="profile-info">
        <h1><%= user.name || user.username %></h1>
        <p>@<%= user.username %></p>
        <div class="profile-stats">
          <div>
            <div class="profile-stat-val"><%= totalSolved %></div>
            <div class="profile-stat-label">Problems Solved</div>
          </div>
          <div>
            <div class="profile-stat-val"><%= activeDays %></div>
            <div class="profile-stat-label">Active Days</div>
          </div>
          <div>
            <div class="profile-stat-val"><%= totalActivity %></div>
            <div class="profile-stat-label">Total Activity</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card" style="animation-delay:0.1s">
      <div class="card-title">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Activity Heatmap
      </div>
      <div class="heatmap-scroll">
        <div class="heatmap-inner">
          <% months.forEach(month => { %>
            <div class="heatmap-month">
              <div class="heatmap-month-name"><%= month.name %></div>
              <div class="heatmap-weeks">
                <% month.weeks.forEach(week => { %>
                  <div class="heatmap-col">
                    <% week.forEach(day => { %>
                      <% const count = day ? day.count : 0; %>
                      <% const color = !day || count === 0 ? '#e2e8f0' : count < 3 ? '#bfdbfe' : count < 6 ? '#60a5fa' : count < 10 ? '#2563eb' : '#1d4ed8'; %>
                      <div class="heatmap-day" style="background:<%= color %>" data-date="<%= day ? day.date : '' %>" data-count="<%= count %>"></div>
                    <% }) %>
                  </div>
                <% }) %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
      <div class="heatmap-legend">
        <span>Less</span>
        <div class="legend-box" style="background:#e2e8f0"></div>
        <div class="legend-box" style="background:#bfdbfe"></div>
        <div class="legend-box" style="background:#60a5fa"></div>
        <div class="legend-box" style="background:#2563eb"></div>
        <div class="legend-box" style="background:#1d4ed8"></div>
        <span>More</span>
      </div>
    </div>

  </div>
</div>

<div id="tooltip"></div>
<script>
  const tooltip = document.getElementById('tooltip');
  document.querySelectorAll('.heatmap-day').forEach(box => {
    box.addEventListener('mouseenter', () => { if (!box.dataset.date) return; tooltip.textContent = box.dataset.date + ' — ' + box.dataset.count + ' activities'; tooltip.style.display = 'block'; });
    box.addEventListener('mousemove', e => { tooltip.style.left = (e.clientX + 12) + 'px'; tooltip.style.top = (e.clientY - 32) + 'px'; });
    box.addEventListener('mouseleave', () => { tooltip.style.display = 'none'; });
  });
</script>
</body>
</html>
