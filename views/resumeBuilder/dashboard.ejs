<!DOCTYPE html>
<html>
<head>

<title>Your Resumes</title>

<style>

body{
font-family:Arial;
background:#f4f6fb;
margin:0;
padding:40px;
}

.header{
display:flex;
justify-content: space-between;
align-items:center;
margin-bottom:30px;
}

.create-btn{
background:#2563eb;
color:white;
padding:10px 18px;
border:none;
border-radius:6px;
cursor:pointer;
margin-left: 10px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(260px,1fr));
gap:20px;
}

.card{
background:white;
padding:20px;
border-radius:8px;
box-shadow:0 0 10px rgba(0,0,0,0.05);
}

.card h3{
margin-top:0;
}

.actions{
margin-top:15px;
display:flex;
gap:10px;
}

.btn{
padding:8px 12px;
border:none;
border-radius:5px;
cursor:pointer;
}

.edit{
background:#2563eb;
color:white;
}

.download{
background:#64748b;
color:white;
}
.icon-btn{
background:none;
border:none;
cursor:pointer;
font-size:14px;
margin-left:8px;
}

.rename-input{
flex:1;
padding:6px;
border:1px solid #ccc;
border-radius:4px;
font-size:13px;
}

.small{
padding:6px 10px;
font-size:12px;
background:#2563eb;
color:white;
}

.btn-delete{
width:24px;
height:24px;
background:#ef4444;
color:white;
border:none;
border-radius:4px;
cursor:pointer;
font-weight:bold;
}

/* MODAL */
.modal{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,0.5);
justify-content:center;
align-items:center;
z-index:1000;
}

.modal-content{
background:white;
padding:25px;
border-radius:8px;
width:320px;
text-align:center;
}

.cancel{
background:#ccc;
color:black;
margin-top:10px;
}

/* LOADER */
.loader-overlay{
display:none;
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(86, 86, 86, 0.421);
z-index:2000;
justify-content:center;
align-items:center;
}

.loader-box{
background:white;
padding:20px 30px;
border-radius:8px;
box-shadow:0 0 10px rgba(0,0,0,0.1);
font-weight:bold;
}

.file-upload{
display:flex;
align-items:center;
gap:10px;
margin-bottom:15px;
}

.file-label{
background:#2563eb;
color:white;
padding:8px 14px;
border-radius:6px;
cursor:pointer;
font-size:14px;
}

.file-label:hover{
background:#5480f9;
}

#fileName{
font-size:13px;
color:#555;
}

.spinner{
width:40px;
height:40px;
border:4px solid #e5e7eb;
border-top:4px solid #2563eb;
border-radius:50%;
animation:spin 1s linear infinite;
margin:auto;
}

@keyframes spin{
0%{ transform:rotate(0deg); }
100%{ transform:rotate(360deg); }
}

.loader-text{
margin-top:12px;
font-size:14px;
color:#333;
text-align:center;
}
</style>

</head>

<body>

<div class="header">

<h2>Your Resumes</h2>


<div class="header">
  <form action="/builder/create" method="GET">
  <button class="create-btn">+ Create New Resume</button>
  </form>
  <button class="create-btn" onclick="openImportModal()">
    Import Resume
  </button>
</div>
</div>
<div id="importModal" class="modal">

  <div class="modal-content">

    <h3>Import Resume</h3>

    <form id="importForm" enctype="multipart/form-data">

      <div class="file-upload">

        <label for="resumeFile" class="file-label">
          Choose Resume
        </label>

        <span id="fileName">No file chosen</span>

        <input 
          id="resumeFile"
          type="file" 
          name="resume" 
          accept=".pdf,.doc,.docx" 
          required
          hidden
        >

      </div>

      <button type="submit" class="create-btn">Upload & Import</button>

      <button type="button" onclick="closeImportModal()" class="btn cancel">
        Cancel
      </button>

    </form>

  </div>

</div>

<div id="loaderOverlay" class="loader-overlay">
  <div class="loader-box">
    <div class="spinner"></div>
      <p class="loader-text">Importing Resume...</p>
  </div>
</div>

<div class="grid">

<% resumes.forEach(resume=>{ %>

<div class="card">

<h3>
  <span id="title-<%= resume._id %>">
    <%= resume.title || "Untitled Resume" %>
  </span>

  <button class="icon-btn" onclick="showRename('<%= resume._id %>')">✏️</button>
</h3>

<div id="rename-box-<%= resume._id %>" style="display:none; margin-bottom:10px;">
  <form action="/builder/<%= resume._id %>/rename" method="POST" style="display:flex; gap:5px;">
    <input name="title" value="<%= resume.title %>" required class="rename-input">
    <button class="btn small">Save</button>
  </form>
</div>

<p>Status: <strong><%= resume.status %></strong></p>

<p>
Updated:
<%= new Date(resume.updatedAt).toLocaleDateString() %>
</p>

<div class="actions">

<a href="/builder/<%= resume._id %>/editor">
<button class="btn edit">Edit</button>
</a>

<a href="/builder/<%= resume._id %>/print">
<button class="btn download">Download</button>
</a>

<form action="/builder/<%= resume._id %>/delete" method="POST">
  <button class="btn-delete">×</button>
</form>

</div>

</div>

<% }) %>

</div>

<script>
function showRename(id){
  const box = document.getElementById("rename-box-"+id)
  box.style.display = box.style.display === "none" ? "block" : "none"
}
</script>
<script>

function openImportModal(){
  document.getElementById("importModal").style.display = "flex"
}

function closeImportModal(){
  document.getElementById("importModal").style.display = "none"
}

// FORM SUBMIT (IMPORTANT)
document.getElementById("importForm").addEventListener("submit", async function(e){

  e.preventDefault()

  const formData = new FormData(this)

  // show loader
  document.getElementById("loaderOverlay").style.display = "flex"

  try{

    const res = await fetch("/builder/import", {
      method: "POST",
      body: formData
    })

    // backend should redirect
    if(res.redirected){
      window.location.href = res.url
    }

  }catch(err){
    alert("Import failed")
  }

})

</script>
<script>

const fileInput = document.getElementById("resumeFile")
const fileName = document.getElementById("fileName")

fileInput.addEventListener("change", function(){
  if(this.files.length > 0){
    fileName.innerText = this.files[0].name
  }else{
    fileName.innerText = "No file chosen"
  }
})

</script>
</body>
</html>