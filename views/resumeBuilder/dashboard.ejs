<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Resume Builder — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--blue:#2563eb;--blue-dark:#1d4ed8;--blue-mid:#3b82f6;--blue-light:#eff6ff;--blue-pale:#dbeafe;--white:#fff;--gray-50:#f8fafc;--gray-100:#f1f5f9;--gray-200:#e2e8f0;--gray-300:#cbd5e1;--gray-400:#94a3b8;--gray-500:#64748b;--gray-600:#475569;--gray-700:#334155;--gray-800:#1e293b;--gray-900:#0f172a;--red:#dc2626;--sidebar-w:260px;--navbar-h:64px;--radius:14px;--shadow-sm:0 1px 3px rgba(0,0,0,0.06);--shadow:0 4px 16px rgba(0,0,0,0.07)}
    body{font-family:'Inter',sans-serif;background:var(--gray-50);color:var(--gray-800);min-height:100vh}
    .navbar{position:fixed;top:0;left:0;right:0;height:var(--navbar-h);background:var(--white);border-bottom:1px solid var(--gray-200);display:flex;align-items:center;padding:0 24px;z-index:100;gap:16px}
    .nav-brand{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:800;color:var(--gray-900);text-decoration:none;letter-spacing:-0.5px}
    .nav-brand-icon{width:36px;height:36px;background:linear-gradient(135deg,var(--blue),var(--blue-mid));border-radius:10px;display:flex;align-items:center;justify-content:center}
    .nav-spacer{flex:1}
    .nav-btn{padding:8px 16px;border-radius:8px;font-size:13px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;border:none;text-decoration:none;display:inline-flex;align-items:center;gap:6px;transition:all 0.15s}
    .nav-btn-ghost{background:transparent;color:var(--gray-600);border:1.5px solid var(--gray-200)}
    .nav-btn-ghost:hover{background:var(--gray-100)}
    .nav-btn-primary{background:linear-gradient(135deg,var(--blue),var(--blue-mid));color:white;box-shadow:0 2px 8px rgba(37,99,235,0.3)}
    .nav-btn-primary:hover{transform:translateY(-1px)}
    .hamburger{display:none;background:none;border:none;cursor:pointer;padding:6px;border-radius:8px;color:var(--gray-600)}
    .sidebar{position:fixed;top:var(--navbar-h);left:0;width:var(--sidebar-w);height:calc(100vh - var(--navbar-h));background:var(--white);border-right:1px solid var(--gray-200);padding:24px 16px;overflow-y:auto;z-index:90;transition:transform 0.3s cubic-bezier(0.16,1,0.3,1)}
    .sidebar-section{margin-bottom:28px}
    .sidebar-label{font-size:10px;font-weight:700;color:var(--gray-400);letter-spacing:1px;text-transform:uppercase;padding:0 12px;margin-bottom:8px}
    .sidebar-link{display:flex;align-items:center;gap:12px;padding:10px 12px;border-radius:10px;font-size:14px;font-weight:500;color:var(--gray-600);text-decoration:none;transition:all 0.15s;margin-bottom:2px}
    .sidebar-link:hover{background:var(--gray-100);color:var(--gray-800)}
    .sidebar-link.active{background:var(--blue-light);color:var(--blue);font-weight:600}
    .s-icon{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:var(--gray-100)}
    .sidebar-link.active .s-icon{background:var(--blue-pale)}
    .sidebar-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.4);z-index:89}
    .main{margin-left:var(--sidebar-w);margin-top:var(--navbar-h);padding:32px}
    .page-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:28px;flex-wrap:wrap;gap:12px;animation:fadeUp 0.4s ease both}
    .page-header h1{font-size:26px;font-weight:800;color:var(--gray-900);letter-spacing:-0.5px}
    .page-header p{font-size:14px;color:var(--gray-500);margin-top:4px}
    .header-actions{display:flex;gap:10px;flex-wrap:wrap}
    /* RESUME GRID */
    .resume-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:16px}
    .resume-card{background:var(--white);border-radius:var(--radius);border:1px solid var(--gray-200);padding:22px;box-shadow:var(--shadow-sm);transition:all 0.2s;animation:fadeUp 0.4s ease both;display:flex;flex-direction:column;gap:14px}
    .resume-card:hover{transform:translateY(-2px);box-shadow:var(--shadow);border-color:var(--blue-pale)}
    .resume-card-top{display:flex;align-items:flex-start;justify-content:space-between;gap:10px}
    .resume-icon{width:44px;height:44px;border-radius:10px;background:var(--blue-light);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .resume-title{font-size:15px;font-weight:700;color:var(--gray-800);margin-bottom:3px;word-break:break-word}
    .resume-meta{font-size:12px;color:var(--gray-400)}
    .status-badge{font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px;white-space:nowrap}
    .status-badge.draft{background:var(--gray-100);color:var(--gray-500)}
    .status-badge.optimized{background:#dcfce7;color:#14532d}
    .rename-form{display:none;gap:6px}
    .rename-form.open{display:flex}
    .rename-input{flex:1;padding:7px 10px;border:1.5px solid var(--gray-200);border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;outline:none}
    .rename-input:focus{border-color:var(--blue)}
    .resume-actions{display:flex;gap:8px;flex-wrap:wrap}
    .btn-sm{padding:7px 14px;border-radius:8px;font-size:12px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;border:none;text-decoration:none;display:inline-flex;align-items:center;gap:5px;transition:all 0.15s}
    .btn-edit{background:var(--blue);color:white}
    .btn-edit:hover{background:var(--blue-dark)}
    .btn-download{background:var(--gray-100);color:var(--gray-700);border:1.5px solid var(--gray-200)}
    .btn-download:hover{background:var(--gray-200)}
    .btn-rename{background:transparent;color:var(--gray-500);border:1.5px solid var(--gray-200)}
    .btn-rename:hover{border-color:var(--blue);color:var(--blue)}
    .btn-delete{background:transparent;color:var(--gray-400);border:1.5px solid var(--gray-200);padding:7px 10px}
    .btn-delete:hover{background:#fee2e2;border-color:#fecaca;color:var(--red)}
    .btn-save-rename{background:var(--blue);color:white;padding:7px 12px;border-radius:8px;font-size:12px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;border:none}
    /* EMPTY STATE */
    .empty-state{text-align:center;padding:60px 20px;animation:fadeUp 0.4s ease both}
    .empty-state svg{margin-bottom:16px;opacity:0.3}
    .empty-state h2{font-size:20px;font-weight:700;color:var(--gray-700);margin-bottom:8px}
    .empty-state p{font-size:14px;color:var(--gray-400);margin-bottom:24px}
    /* MODAL */
    .modal{display:none;position:fixed;inset:0;background:rgba(15,23,42,0.6);z-index:200;justify-content:center;align-items:center;backdrop-filter:blur(4px)}
    .modal.open{display:flex}
    .modal-card{background:var(--white);border-radius:20px;padding:32px;width:100%;max-width:420px;box-shadow:0 24px 64px rgba(0,0,0,0.2);animation:scaleIn 0.25s cubic-bezier(0.16,1,0.3,1) both}
    @keyframes scaleIn{from{opacity:0;transform:scale(0.92)}to{opacity:1;transform:scale(1)}}
    .modal-title{font-size:18px;font-weight:800;color:var(--gray-900);margin-bottom:6px}
    .modal-sub{font-size:13px;color:var(--gray-500);margin-bottom:20px}
    .upload-box{border:2px dashed var(--gray-300);border-radius:12px;padding:32px 20px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--gray-50);position:relative;margin-bottom:16px}
    .upload-box:hover,.upload-box.dragover{border-color:var(--blue);background:var(--blue-light)}
    .upload-box input[type="file"]{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
    .upload-box-title{font-size:14px;font-weight:600;color:var(--gray-700);margin-bottom:4px}
    .upload-box-sub{font-size:12px;color:var(--gray-400)}
    .file-selected{font-size:13px;font-weight:600;color:var(--blue);margin-top:8px;display:none}
    .modal-actions{display:flex;gap:10px}
    .btn-modal-primary{flex:1;padding:11px;background:linear-gradient(135deg,var(--blue),var(--blue-mid));color:white;border:none;border-radius:10px;font-size:14px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;transition:all 0.15s;box-shadow:0 4px 14px rgba(37,99,235,0.3)}
    .btn-modal-primary:hover{transform:translateY(-1px)}
    .btn-modal-cancel{padding:11px 18px;background:transparent;color:var(--gray-600);border:1.5px solid var(--gray-200);border-radius:10px;font-size:14px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;transition:all 0.15s}
    .btn-modal-cancel:hover{background:var(--gray-100)}
    /* LOADER */
    .loader-overlay{display:none;position:fixed;inset:0;background:rgba(15,23,42,0.72);z-index:300;justify-content:center;align-items:center;backdrop-filter:blur(8px)}
    .loader-overlay.open{display:flex}

    /* Import loader card */
    .import-loader-card{
      background:white;border-radius:24px;
      padding:44px 40px;width:420px;max-width:calc(100vw - 40px);
      text-align:center;
      box-shadow:0 32px 80px rgba(0,0,0,0.28);
      animation:importCardIn 0.4s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes importCardIn{from{opacity:0;transform:scale(0.92) translateY(16px)}to{opacity:1;transform:scale(1) translateY(0)}}

    /* Animated document icon */
    .import-doc-wrap{
      width:80px;height:96px;
      margin:0 auto 24px;
      position:relative;
    }
    .import-doc{
      width:80px;height:96px;
      background:#eff6ff;
      border-radius:10px;
      border:2px solid #dbeafe;
      position:relative;
      overflow:hidden;
    }
    /* Folded corner */
    .import-doc::before{
      content:'';
      position:absolute;top:0;right:0;
      width:22px;height:22px;
      background:white;
      border-bottom-left-radius:6px;
      border-left:2px solid #dbeafe;
      border-bottom:2px solid #dbeafe;
    }
    /* Fake text lines */
    .import-doc-lines{
      position:absolute;
      top:28px;left:12px;right:12px;
      display:flex;flex-direction:column;gap:6px;
    }
    .import-doc-line{
      height:5px;border-radius:3px;
      background:#bfdbfe;
      animation:lineShimmer 1.6s ease-in-out infinite;
    }
    .import-doc-line:nth-child(1){width:100%;animation-delay:0s}
    .import-doc-line:nth-child(2){width:80%;animation-delay:0.15s}
    .import-doc-line:nth-child(3){width:90%;animation-delay:0.3s}
    .import-doc-line:nth-child(4){width:65%;animation-delay:0.45s}
    .import-doc-line:nth-child(5){width:85%;animation-delay:0.6s}
    @keyframes lineShimmer{
      0%,100%{opacity:0.4;transform:scaleX(1)}
      50%{opacity:1;transform:scaleX(1.02)}
    }

    /* Scan line sweeping over the doc */
    .import-scan-line{
      position:absolute;
      left:0;right:0;height:3px;
      background:linear-gradient(90deg,transparent,#2563eb,#60a5fa,#2563eb,transparent);
      box-shadow:0 0 10px 3px rgba(37,99,235,0.4);
      animation:scanSweep 1.8s ease-in-out infinite;
      top:0;
    }
    @keyframes scanSweep{
      0%{top:0%;opacity:0}
      5%{opacity:1}
      95%{opacity:1}
      100%{top:100%;opacity:0}
    }

    /* Floating particles around doc */
    .import-particle{
      position:absolute;
      width:5px;height:5px;
      border-radius:50%;
      background:#3b82f6;
      animation:particlePop ease-in-out infinite;
    }
    .import-particle:nth-child(1){top:-8px;left:10px;animation-duration:2s;animation-delay:0s}
    .import-particle:nth-child(2){top:20px;right:-10px;animation-duration:2.4s;animation-delay:0.6s;background:#60a5fa}
    .import-particle:nth-child(3){bottom:10px;left:-10px;animation-duration:1.8s;animation-delay:1.2s;background:#93c5fd}
    @keyframes particlePop{
      0%,100%{transform:scale(0);opacity:0}
      50%{transform:scale(1);opacity:1}
    }

    .import-loader-title{font-size:18px;font-weight:800;color:#1e293b;margin-bottom:6px;letter-spacing:-0.3px}
    .import-loader-sub{font-size:13px;color:#64748b;line-height:1.6;margin-bottom:24px}

    /* Steps */
    .import-steps{text-align:left;display:flex;flex-direction:column;gap:9px;margin-bottom:20px}
    .import-step{display:flex;align-items:center;gap:10px;font-size:13px;color:#94a3b8;font-weight:500;transition:color 0.4s}
    .import-step.active{color:#1e293b}
    .import-step.done{color:#16a34a}
    .import-step-dot{width:7px;height:7px;border-radius:50%;background:#e2e8f0;flex-shrink:0;transition:background 0.4s}
    .import-step.active .import-step-dot{background:#2563eb;animation:dotPulse2 1s ease-in-out infinite}
    .import-step.done .import-step-dot{background:#16a34a;animation:none}
    @keyframes dotPulse2{0%,100%{transform:scale(1)}50%{transform:scale(1.6)}}

    /* Progress bar */
    .import-progress-track{height:5px;background:#e2e8f0;border-radius:10px;overflow:hidden}
    .import-progress-fill{height:100%;width:0%;border-radius:10px;background:linear-gradient(90deg,#2563eb,#3b82f6);transition:width 0.5s ease}
    @keyframes fadeUp{from{opacity:0;transform:translateY(14px)}to{opacity:1;transform:translateY(0)}}
    @media(max-width:768px){.hamburger{display:flex}.sidebar{transform:translateX(-100%)}.sidebar.open{transform:translateX(0);box-shadow:4px 0 24px rgba(0,0,0,0.12)}.sidebar-overlay.open{display:block}.main{margin-left:0;padding:20px 16px}}
  </style>
</head>
<body>

<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn"><svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/></svg></button>
  <a href="/dashboard" class="nav-brand"><div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div>PrepPilot</a>
  <div class="nav-spacer"></div>
  <a href="/dashboard" class="nav-btn nav-btn-ghost">Dashboard</a>
</nav>
<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard</a>
    <a href="/roadmap" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> Roadmap</a>
    <a href="/activity/activity-dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span> DSA Activity</a>

  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <a href="/builder" class="sidebar-link active"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span> Resume Builder</a>
    <a href="/resume" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span> ATS Analyzer</a>
    <a href="/api/interview/setup" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></span> AI Interview</a>

  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> Profile</a>
    <a href="/logout" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="page-header">
    <div>
      <h1>Resume Builder</h1>
      <p>Create, edit, and AI-optimize your resumes</p>
    </div>
    <div class="header-actions">
      <button class="nav-btn nav-btn-ghost" onclick="openImportModal()">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Import Resume
      </button>
      <a href="/builder/create" class="nav-btn nav-btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        New Resume
      </a>
    </div>
  </div>

  <% if (resumes.length === 0) { %>
    <div class="empty-state">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      <h2>No resumes yet</h2>
      <p>Create your first resume or import an existing one to get started.</p>
      <a href="/builder/create" class="nav-btn nav-btn-primary" style="display:inline-flex;">Create Resume</a>
    </div>
  <% } else { %>
    <div class="resume-grid">
      <% resumes.forEach((resume, i) => { %>
        <div class="resume-card" style="animation-delay:<%= i * 0.05 %>s">
          <div class="resume-card-top">
            <div style="display:flex;align-items:flex-start;gap:12px;">
              <div class="resume-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
              </div>
              <div>
                <div class="resume-title" id="title-<%= resume._id %>"><%= resume.title || 'Untitled Resume' %></div>
                <div class="resume-meta">Updated <%= new Date(resume.updatedAt).toLocaleDateString('en-US', {month:'short', day:'numeric', year:'numeric'}) %></div>
              </div>
            </div>
            <span class="status-badge <%= resume.status === 'optimized' ? 'optimized' : 'draft' %>"><%= resume.status || 'draft' %></span>
          </div>

          <div class="rename-form" id="rename-<%= resume._id %>">
            <form action="/builder/<%= resume._id %>/rename" method="POST" style="display:flex;gap:6px;width:100%">
              <input name="title" value="<%= resume.title %>" required class="rename-input" placeholder="Resume name"/>
              <button type="submit" class="btn-save-rename">Save</button>
            </form>
          </div>

          <div class="resume-actions">
            <a href="/builder/<%= resume._id %>/editor" class="btn-sm btn-edit">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Edit
            </a>
            <a href="/builder/<%= resume._id %>/print" class="btn-sm btn-download">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
              Download
            </a>
            <button class="btn-sm btn-rename" onclick="toggleRename('<%= resume._id %>')">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
              Rename
            </button>
            <form action="/builder/<%= resume._id %>/delete" method="POST" style="display:inline">
              <button type="submit" class="btn-sm btn-delete" onclick="return confirm('Delete this resume?')">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
              </button>
            </form>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</main>

<!-- IMPORT MODAL -->
<div class="modal" id="importModal">
  <div class="modal-card">
    <div class="modal-title">Import Resume</div>
    <div class="modal-sub">Upload a PDF or DOCX file and we'll parse it into the builder.</div>
    <form id="importForm" enctype="multipart/form-data">
      <div class="upload-box" id="uploadBox">
        <input type="file" id="resumeFile" name="resume" accept=".pdf,.doc,.docx" required/>
        <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom:10px"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
        <div class="upload-box-title">Drop your resume here or click to browse</div>
        <div class="upload-box-sub">PDF, DOC, DOCX supported</div>
        <div class="file-selected" id="fileName"></div>
      </div>
      <div class="modal-actions">
        <button type="submit" class="btn-modal-primary">Import</button>
        <button type="button" class="btn-modal-cancel" onclick="closeImportModal()">Cancel</button>
      </div>
    </form>
  </div>
</div>

<!-- IMPORT LOADER -->
<div class="loader-overlay" id="loaderOverlay">
  <div class="import-loader-card">

    <div class="import-doc-wrap">
      <div class="import-doc">
        <div class="import-scan-line"></div>
        <div class="import-doc-lines">
          <div class="import-doc-line"></div>
          <div class="import-doc-line"></div>
          <div class="import-doc-line"></div>
          <div class="import-doc-line"></div>
          <div class="import-doc-line"></div>
        </div>
      </div>
      <div class="import-particle"></div>
      <div class="import-particle"></div>
      <div class="import-particle"></div>
    </div>

    <div class="import-loader-title">Importing your resume</div>
    <div class="import-loader-sub">AI is reading and parsing your document into the builder</div>

    <div class="import-steps">
      <div class="import-step active" id="is1"><div class="import-step-dot"></div><span>Reading document content</span></div>
      <div class="import-step" id="is2"><div class="import-step-dot"></div><span>Extracting sections and details</span></div>
      <div class="import-step" id="is3"><div class="import-step-dot"></div><span>Structuring into builder format</span></div>
    </div>

    <div class="import-progress-track">
      <div class="import-progress-fill" id="importProgress"></div>
    </div>

  </div>
</div>

<script>
  document.getElementById('hamburgerBtn').addEventListener('click',()=>{document.getElementById('sidebar').classList.toggle('open');document.getElementById('sidebarOverlay').classList.toggle('open')});
  document.getElementById('sidebarOverlay').addEventListener('click',()=>{document.getElementById('sidebar').classList.remove('open');document.getElementById('sidebarOverlay').classList.remove('open')});

  function toggleRename(id) {
    const box = document.getElementById('rename-' + id);
    box.classList.toggle('open');
  }

  function openImportModal() { document.getElementById('importModal').classList.add('open'); }
  function closeImportModal() { document.getElementById('importModal').classList.remove('open'); }

  document.getElementById('resumeFile').addEventListener('change', function() {
    const fn = document.getElementById('fileName');
    if (this.files.length > 0) { fn.textContent = this.files[0].name; fn.style.display = 'block'; }
  });

  document.getElementById('importForm').addEventListener('submit', async function(e) {
    e.preventDefault();
    const formData = new FormData(this);

    // Show loader and animate steps
    document.getElementById('loaderOverlay').classList.add('open');
    const steps = [
      { id: 'is1', progress: 25,  delay: 0 },
      { id: 'is2', progress: 60,  delay: 1500 },
      { id: 'is3', progress: 85,  delay: 3000 },
    ];
    const fill = document.getElementById('importProgress');
    steps.forEach((s, i) => {
      setTimeout(() => {
        if (i > 0) {
          const prev = document.getElementById(steps[i-1].id);
          prev.classList.remove('active'); prev.classList.add('done');
        }
        document.getElementById(s.id).classList.add('active');
        fill.style.width = s.progress + '%';
      }, s.delay);
    });

    try {
      const res = await fetch('/builder/import', { method: 'POST', body: formData });
      if (res.redirected) {
        fill.style.width = '100%';
        window.location.href = res.url;
      }
    } catch(err) {
      document.getElementById('loaderOverlay').classList.remove('open');
      alert('Import failed. Please try again.');
    }
  });
</script>
</body>
</html>
