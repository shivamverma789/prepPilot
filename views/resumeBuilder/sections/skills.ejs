<style>
.sec-input{width:100%;padding:9px 12px;border:1.5px solid #e2e8f0;border-radius:8px;font-size:13px;font-family:'Inter',sans-serif;color:#1e293b;background:#f8fafc;outline:none;transition:border-color 0.2s,box-shadow 0.2s}
.sec-input:focus{border-color:#2563eb;background:#fff;box-shadow:0 0 0 3px rgba(37,99,235,0.08)}
.sec-label{font-size:12px;font-weight:600;color:#475569;margin-bottom:5px;display:block}
.add-group-row{display:flex;gap:8px;margin-bottom:16px}
.sec-btn-sm{padding:9px 14px;background:linear-gradient(135deg,#2563eb,#3b82f6);color:white;border:none;border-radius:8px;font-size:12px;font-weight:700;font-family:'Inter',sans-serif;cursor:pointer;white-space:nowrap;transition:all 0.15s;flex-shrink:0}
.sec-btn-sm:hover{transform:translateY(-1px)}
.skill-group-card{background:#f8fafc;border:1.5px solid #e2e8f0;border-radius:10px;padding:14px;margin-bottom:10px}

/* header: group name on top row, actions below */
.skill-group-header{display:flex;flex-direction:column;gap:8px;margin-bottom:10px}
.skill-group-name-row{display:flex;align-items:center;justify-content:space-between;gap:8px}
.skill-group-name{font-size:13px;font-weight:700;color:#1e293b;flex:1;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.skill-group-actions{display:flex;gap:6px;align-items:center;flex-shrink:0}
.skill-rename-row{display:flex;gap:6px;align-items:center}
.skill-rename-input{flex:1;padding:6px 10px;border:1.5px solid #e2e8f0;border-radius:7px;font-size:12px;font-family:'Inter',sans-serif;color:#1e293b;background:#fff;outline:none;min-width:0}
.skill-rename-input:focus{border-color:#2563eb}

.btn-ghost-sm{padding:5px 10px;background:transparent;border:1.5px solid #e2e8f0;border-radius:6px;font-size:11px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;color:#64748b;transition:all 0.15s;white-space:nowrap;flex-shrink:0}
.btn-ghost-sm:hover{border-color:#2563eb;color:#2563eb}
.btn-del-sm{padding:5px 8px;background:transparent;border:1.5px solid #fecaca;border-radius:6px;font-size:11px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;color:#dc2626;transition:all 0.15s;white-space:nowrap;flex-shrink:0}
.btn-del-sm:hover{background:#fee2e2}
.skills-save-row{display:flex;gap:8px;margin-top:8px}
</style>

<% const skillsSection = resume.sections.find(s => s.title === 'Skills') %>

<div style="margin-bottom:16px;">
  <label class="sec-label">Add Skill Group</label>
  <form method="POST" action="/builder/<%= resume._id %>/skills/group">
    <div class="add-group-row">
      <input name="groupName" class="sec-input" placeholder="e.g. Frontend, Backend, Tools" required/>
      <button type="submit" class="sec-btn-sm">Add Group</button>
    </div>
  </form>
</div>

<% skillsSection.data.forEach((group, index) => { %>
  <div class="skill-group-card">
    <div class="skill-group-header">
      <!-- Top row: name + delete -->
      <div class="skill-group-name-row">
        <span class="skill-group-name"><%= group.group %></span>
        <div class="skill-group-actions">
          <form method="POST" action="/builder/<%= resume._id %>/skills/<%= index %>/delete" style="display:inline">
            <button type="submit" class="btn-del-sm">Delete</button>
          </form>
        </div>
      </div>
      <!-- Second row: rename -->
      <form method="POST" action="/builder/<%= resume._id %>/skills/<%= index %>/name" class="skill-rename-row">
        <input name="groupName" value="<%= group.group %>" class="skill-rename-input" placeholder="Rename group"/>
        <button type="submit" class="btn-ghost-sm">Rename</button>
      </form>
    </div>
    <form method="POST" action="/builder/<%= resume._id %>/skills/<%= index %>">
      <input name="skills" class="sec-input" value="<%= group.items.join(', ') %>" placeholder="HTML, CSS, JavaScript (comma separated)"/>
      <div class="skills-save-row">
        <button type="submit" class="sec-btn-sm">Save Skills</button>
      </div>
    </form>
  </div>
<% }) %>

<% if (skillsSection.data.length === 0) { %>
  <div style="text-align:center;padding:24px;color:#94a3b8;font-size:13px;background:#f8fafc;border-radius:10px;border:1.5px dashed #e2e8f0;">
    No skill groups yet. Add one above to get started.
  </div>
<% } %>
