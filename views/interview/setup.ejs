<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>AI Interview Setup — PrepPilot</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --blue: #2563eb; --blue-dark: #1d4ed8; --blue-mid: #3b82f6;
      --blue-light: #eff6ff; --blue-pale: #dbeafe;
      --white: #fff; --gray-50: #f8fafc; --gray-100: #f1f5f9;
      --gray-200: #e2e8f0; --gray-400: #94a3b8; --gray-500: #64748b;
      --gray-600: #475569; --gray-700: #334155; --gray-800: #1e293b; --gray-900: #0f172a;
      --sidebar-w: 260px; --navbar-h: 64px; --radius: 14px;
      --shadow-sm: 0 1px 3px rgba(0,0,0,0.06); --shadow: 0 4px 16px rgba(0,0,0,0.07);
    }

    body { font-family: 'Inter', sans-serif; background: var(--gray-50); color: var(--gray-800); min-height: 100vh; }

    .navbar { position: fixed; top: 0; left: 0; right: 0; height: var(--navbar-h); background: var(--white); border-bottom: 1px solid var(--gray-200); display: flex; align-items: center; padding: 0 24px; z-index: 100; gap: 16px; }
    .nav-brand { display: flex; align-items: center; gap: 10px; font-size: 18px; font-weight: 800; color: var(--gray-900); text-decoration: none; letter-spacing: -0.5px; }
    .nav-brand-icon { width: 36px; height: 36px; background: linear-gradient(135deg, var(--blue), var(--blue-mid)); border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 18px; }
    .nav-spacer { flex: 1; }
    .nav-btn { padding: 8px 16px; border-radius: 8px; font-size: 13px; font-weight: 600; font-family: 'Inter', sans-serif; cursor: pointer; border: none; text-decoration: none; display: inline-flex; align-items: center; gap: 6px; transition: all 0.15s; }
    .nav-btn-ghost { background: transparent; color: var(--gray-600); border: 1.5px solid var(--gray-200); }
    .nav-btn-ghost:hover { background: var(--gray-100); }
    .hamburger { display: none; background: none; border: none; cursor: pointer; padding: 6px; border-radius: 8px; color: var(--gray-600); }

    .sidebar { position: fixed; top: var(--navbar-h); left: 0; width: var(--sidebar-w); height: calc(100vh - var(--navbar-h)); background: var(--white); border-right: 1px solid var(--gray-200); padding: 24px 16px; overflow-y: auto; z-index: 90; transition: transform 0.3s cubic-bezier(0.16,1,0.3,1); }
    .sidebar-section { margin-bottom: 28px; }
    .sidebar-label { font-size: 10px; font-weight: 700; color: var(--gray-400); letter-spacing: 1px; text-transform: uppercase; padding: 0 12px; margin-bottom: 8px; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 10px; font-size: 14px; font-weight: 500; color: var(--gray-600); text-decoration: none; transition: all 0.15s; margin-bottom: 2px; }
    .sidebar-link:hover { background: var(--gray-100); color: var(--gray-800); }
    .sidebar-link.active { background: var(--blue-light); color: var(--blue); font-weight: 600; }
    .sidebar-link .s-icon { width: 32px; height: 32px; border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; flex-shrink: 0; background: var(--gray-100); }
    .sidebar-link.active .s-icon { background: var(--blue-pale); }
    .sidebar-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.4); z-index: 89; }

    .main { margin-left: var(--sidebar-w); margin-top: var(--navbar-h); padding: 32px; display: flex; justify-content: center; }
    .content-wrap { width: 100%; max-width: 820px; animation: fadeUp 0.4s ease both; }

    .page-header { margin-bottom: 28px; }
    .page-header h1 { font-size: 26px; font-weight: 800; color: var(--gray-900); letter-spacing: -0.5px; }
    .page-header p { font-size: 14px; color: var(--gray-500); margin-top: 4px; }

    /* HERO BANNER */
    .hero-banner {
      background: linear-gradient(135deg, var(--gray-900) 0%, #1e3a5f 100%);
      border-radius: var(--radius); padding: 32px;
      margin-bottom: 24px; color: white;
      display: flex; align-items: center; gap: 24px; flex-wrap: wrap;
    }
    .hero-icon { font-size: 56px; flex-shrink: 0; }
    .hero-text h2 { font-size: 22px; font-weight: 800; margin-bottom: 6px; }
    .hero-text p { font-size: 14px; opacity: 0.75; line-height: 1.5; }
    .hero-chips { display: flex; gap: 8px; margin-top: 12px; flex-wrap: wrap; }
    .hero-chip { background: rgba(255,255,255,0.1); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }

    /* CARD */
    .card { background: var(--white); border-radius: var(--radius); border: 1px solid var(--gray-200); box-shadow: var(--shadow-sm); padding: 24px; margin-bottom: 16px; }
    .card-title { font-size: 14px; font-weight: 700; color: var(--gray-700); margin-bottom: 14px; display: flex; align-items: center; gap: 8px; }

    /* ROLE INPUT */
    .role-input-wrap { position: relative; margin-bottom: 14px; }
    .role-input-wrap input {
      width: 100%; padding: 12px 16px;
      border: 1.5px solid var(--gray-200); border-radius: 10px;
      font-size: 15px; font-family: 'Inter', sans-serif;
      color: var(--gray-800); background: var(--gray-50); outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .role-input-wrap input:focus { border-color: var(--blue); background: var(--white); box-shadow: 0 0 0 4px rgba(37,99,235,0.08); }

    .role-chips { display: flex; flex-wrap: wrap; gap: 8px; }
    .role-chip {
      padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500;
      background: var(--gray-100); color: var(--gray-600);
      cursor: pointer; border: 1.5px solid transparent;
      transition: all 0.15s;
    }
    .role-chip:hover { background: var(--blue-light); color: var(--blue); border-color: var(--blue-pale); }

    /* OPTION GRID */
    .option-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }

    /* TOGGLE BUTTONS */
    .toggle-group { display: flex; gap: 6px; flex-wrap: wrap; }
    .toggle-btn {
      flex: 1; min-width: 70px; padding: 9px 12px;
      border-radius: 8px; border: 1.5px solid var(--gray-200);
      background: var(--white); color: var(--gray-600);
      font-size: 13px; font-weight: 600; font-family: 'Inter', sans-serif;
      cursor: pointer; transition: all 0.15s; text-align: center;
    }
    .toggle-btn:hover { border-color: var(--blue); color: var(--blue); background: var(--blue-light); }
    .toggle-btn.active-level { background: var(--blue); color: white; border-color: var(--blue); }
    .toggle-btn.active-company { background: #16a34a; color: white; border-color: #16a34a; }
    .toggle-btn.active-type { background: #7c3aed; color: white; border-color: #7c3aed; }
    .toggle-btn.active-duration { background: #dc2626; color: white; border-color: #dc2626; }

    /* FOCUS CHIPS */
    .focus-wrap { display: flex; flex-wrap: wrap; gap: 8px; }
    .focus-chip {
      padding: 7px 14px; border-radius: 20px; font-size: 13px; font-weight: 500;
      background: var(--gray-100); color: var(--gray-600);
      cursor: pointer; border: 1.5px solid transparent;
      transition: all 0.15s; user-select: none;
    }
    .focus-chip:hover { background: var(--blue-light); color: var(--blue); }
    .focus-chip.active { background: #fef3c7; color: #92400e; border-color: #fde68a; font-weight: 600; }

    .focus-counter { font-size: 12px; color: var(--gray-400); margin-bottom: 12px; }

    /* SUBMIT */
    .submit-btn {
      width: 100%; padding: 15px;
      background: linear-gradient(135deg, var(--gray-900), #1e3a5f);
      color: white; border: none; border-radius: 10px;
      font-size: 16px; font-weight: 700; font-family: 'Inter', sans-serif;
      cursor: pointer; transition: all 0.15s;
      box-shadow: 0 4px 14px rgba(15,23,42,0.3);
      display: flex; align-items: center; justify-content: center; gap: 10px;
    }
    .submit-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(15,23,42,0.4); }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }

    @media (max-width: 768px) {
      .hamburger { display: flex; }
      .sidebar { transform: translateX(-100%); }
      .sidebar.open { transform: translateX(0); box-shadow: 4px 0 24px rgba(0,0,0,0.12); }
      .sidebar-overlay.open { display: block; }
      .main { margin-left: 0; padding: 20px 16px; }
      .option-grid { grid-template-columns: 1fr; }
      .hero-banner { flex-direction: column; }
    }
  </style>
</head>
<body>

<nav class="navbar">
  <button class="hamburger" id="hamburgerBtn">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="6" x2="19" y2="6"/><line x1="3" y1="11" x2="19" y2="11"/><line x1="3" y1="16" x2="19" y2="16"/>
    </svg>
  </button>
  <a href="/dashboard" class="nav-brand"><div class="nav-brand-icon"><svg width="20" height="20" viewBox="0 0 24 24" fill="none"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></div> PrepPilot</a>
  <div class="nav-spacer"></div>
  <a href="/dashboard" class="nav-btn nav-btn-ghost">← Dashboard</a>
</nav>

<div class="sidebar-overlay" id="sidebarOverlay"></div>
<aside class="sidebar" id="sidebar">
  <div class="sidebar-section">
    <div class="sidebar-label">Main</div>
    <a href="/dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg></span> Dashboard</a>
    <a href="/roadmap" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l19-9-9 19-2-8-8-2z"/></svg></span> Roadmap</a>
    <a href="/activity/activity-dashboard" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg></span> DSA Activity</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Tools</div>
    <a href="/builder" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg></span> Resume Builder</a>
    <a href="/resume" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span> ATS Analyzer</a>
    <a href="/api/interview/setup" class="sidebar-link active"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></span> AI Interview</a>
  </div>
  <div class="sidebar-section">
    <div class="sidebar-label">Account</div>
    <a href="/profile" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></span> Profile</a>
    <a href="/logout" class="sidebar-link"><span class="s-icon"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg></span> Logout</a>
  </div>
</aside>

<main class="main">
  <div class="content-wrap">

    <div class="hero-banner">
      <div class="hero-icon"><svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg></div>
      <div class="hero-text">
        <h2>AI Mock Interview</h2>
        <p>Configure your interview session and practice with an AI interviewer in real-time. Get instant feedback on your answers.</p>
        <div class="hero-chips">
          <span class="hero-chip">AI-Powered</span>
          <span class="hero-chip">Role-Specific</span>
          <span class="hero-chip">Instant Feedback</span>
        </div>
      </div>
    </div>

    <form id="interviewForm">

      <!-- ROLE -->
      <div class="card">
        <div class="card-title">Target Role</div>
        <div class="role-input-wrap">
          <input id="roleInput" placeholder="e.g. Backend Developer, Data Scientist..." required/>
        </div>
        <div class="role-chips">
          <span class="role-chip">Backend Developer</span>
          <span class="role-chip">Frontend Developer</span>
          <span class="role-chip">Full Stack Developer</span>
          <span class="role-chip">Data Scientist</span>
          <span class="role-chip">DevOps Engineer</span>
          <span class="role-chip">ML Engineer</span>
        </div>
      </div>

      <!-- OPTIONS GRID -->
      <div class="option-grid">

        <div class="card">
          <div class="card-title">Experience Level</div>
          <div class="toggle-group">
            <button type="button" class="toggle-btn level active-level" data-val="beginner">Beginner</button>
            <button type="button" class="toggle-btn level" data-val="intermediate">Intermediate</button>
            <button type="button" class="toggle-btn level" data-val="advanced">Advanced</button>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Company Type</div>
          <div class="toggle-group">
            <button type="button" class="toggle-btn company active-company" data-val="product">Product</button>
            <button type="button" class="toggle-btn company" data-val="service">Service</button>
            <button type="button" class="toggle-btn company" data-val="startup">Startup</button>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Interview Type</div>
          <div class="toggle-group">
            <button type="button" class="toggle-btn type active-type" data-val="technical">Technical</button>
            <button type="button" class="toggle-btn type" data-val="system-design">System</button>
            <button type="button" class="toggle-btn type" data-val="hr">HR</button>
            <button type="button" class="toggle-btn type" data-val="mixed">Mixed</button>
          </div>
        </div>

        <div class="card">
          <div class="card-title">Duration</div>
          <div class="toggle-group">
            <button type="button" class="toggle-btn duration" data-val="short">Short</button>
            <button type="button" class="toggle-btn duration active-duration" data-val="medium">Medium</button>
            <button type="button" class="toggle-btn duration" data-val="long">Long</button>
          </div>
        </div>

      </div>

      <!-- FOCUS AREAS -->
      <div class="card">
        <div class="card-title">Focus Areas</div>
        <div class="focus-counter" id="focusCounter">Select up to 4 topics</div>
        <div class="focus-wrap">
          <span class="focus-chip">DSA</span>
          <span class="focus-chip">DBMS</span>
          <span class="focus-chip">OS</span>
          <span class="focus-chip">Computer Networks</span>
          <span class="focus-chip">OOPs</span>
          <span class="focus-chip">Backend Development</span>
          <span class="focus-chip">Frontend Development</span>
          <span class="focus-chip">API Design</span>
          <span class="focus-chip">Microservices</span>
          <span class="focus-chip">System Design</span>
          <span class="focus-chip">Low-Level Design</span>
          <span class="focus-chip">Scalability</span>
          <span class="focus-chip">Caching</span>
          <span class="focus-chip">React</span>
          <span class="focus-chip">JavaScript</span>
          <span class="focus-chip">SQL</span>
          <span class="focus-chip">Database Design</span>
          <span class="focus-chip">Debugging</span>
          <span class="focus-chip">Code Optimization</span>
          <span class="focus-chip">Behavioral</span>
        </div>
      </div>

      <button type="submit" class="submit-btn">
        Start Interview Session
      </button>

    </form>

  </div>
</main>

<script>
  document.getElementById('hamburgerBtn').addEventListener('click', () => {
    document.getElementById('sidebar').classList.toggle('open');
    document.getElementById('sidebarOverlay').classList.toggle('open');
  });
  document.getElementById('sidebarOverlay').addEventListener('click', () => {
    document.getElementById('sidebar').classList.remove('open');
    document.getElementById('sidebarOverlay').classList.remove('open');
  });

  const selected = { level: 'beginner', company: 'product', type: 'technical', duration: 'medium', focus: [] };

  // Role chips
  document.querySelectorAll('.role-chip').forEach(c => {
    c.addEventListener('click', () => { document.getElementById('roleInput').value = c.textContent; });
  });

  // Toggle groups
  function setupToggle(selector, key, activeClass) {
    document.querySelectorAll(selector).forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll(selector).forEach(b => b.classList.remove(activeClass));
        btn.classList.add(activeClass);
        selected[key] = btn.dataset.val;
      });
    });
  }
  setupToggle('.toggle-btn.level', 'level', 'active-level');
  setupToggle('.toggle-btn.company', 'company', 'active-company');
  setupToggle('.toggle-btn.type', 'type', 'active-type');
  setupToggle('.toggle-btn.duration', 'duration', 'active-duration');

  // Focus chips
  document.querySelectorAll('.focus-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      const val = chip.textContent;
      if (!chip.classList.contains('active') && selected.focus.length >= 4) {
        chip.style.animation = 'shake 0.3s ease';
        setTimeout(() => chip.style.animation = '', 300);
        return;
      }
      chip.classList.toggle('active');
      if (selected.focus.includes(val)) {
        selected.focus = selected.focus.filter(f => f !== val);
      } else {
        selected.focus.push(val);
      }
      const count = selected.focus.length;
      document.getElementById('focusCounter').textContent =
        count === 0 ? 'Select up to 4 topics' : `${count}/4 selected`;
    });
  });

  // Submit
  document.getElementById('interviewForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const role = document.getElementById('roleInput').value.trim();
    if (!role) { document.getElementById('roleInput').focus(); return; }

    await fetch('<%= serverUrl %>/api/interview/set-interview-data', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role, ...selected }),
      credentials: 'include'
    });

    window.open('<%= liveKitUrl %>', '_blank');
  });
</script>

<style>
  @keyframes shake {
    0%, 100% { transform: translateX(0); }
    25% { transform: translateX(-4px); }
    75% { transform: translateX(4px); }
  }
</style>

</body>
</html>
